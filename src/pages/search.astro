---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import GameSearch from '../components/GameSearch.tsx';
import GameRow from '../components/GameRow.astro';
import { fetchDiscover } from '../lib/api';

const topRated = await fetchDiscover({ sort: 'rating', limit: 12 });
---

<Layout>
  <div class="page">
    <Nav />
    <main class="container">
      <h1>Search games</h1>
      <GameSearch client:only="react" />

      <div class="divider"><span>Or browse recommended</span></div>

      <GameRow title="Top Rated by Critics" items={topRated} href="/browse?sort=rating" />
    </main>
  </div>
</Layout>

<style>
  :global(body) { background: #0b0d10; color: #e6e8eb; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; }
  .page { min-height: 100vh; }
  .container { max-width: 72rem; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }
  h1 { margin: 0 0 1.5rem; letter-spacing: -0.02em; }

  .divider {
    display: flex; align-items: center; gap: 1rem;
    color: #9aa3ad; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em;
    margin: 2.5rem 0 1.5rem;
  }
  .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #1f242b; }
</style>
