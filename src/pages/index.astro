  /* Portrait 2:3 thumb sized to the inner content height of a 168px card
     (168 − 16px padding × 2 = 136px). Width 92px keeps the SGDB 600×900 /
     IGDB cover almost exactly 2:3, so there's effectively no crop. */
  .cal-v2 .cal-game-cover {
    width: 92px; height: 136px;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
