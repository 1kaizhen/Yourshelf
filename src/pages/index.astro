---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import CardRowSection from '../components/CardRowSection.astro';
import { fetchDiscover, fetchGameDetail, fetchFeaturedList, fetchNewest, fetchCardsByIds, fetchCalendar, fetchBrowseCategories, fetchFreeGames, type GameDetail, type GameLite } from '../lib/api';

const { supabase, user } = Astro.locals;

// "Games in your list" needs the logged-in user's most-recent IGDB IDs from
// Supabase first; everything else (enrichment with rating/genres/cover) is
// done server-side by the Yourshelf-api /api/cards endpoint.
let myGameIds: number[] = [];
if (user) {
  const { data: rows } = await supabase
    .from('user_games')
    .select('igdb_id, updated_at')
    .eq('user_id', user.id)
    .order('updated_at', { ascending: false })
    .limit(6);
  myGameIds = (rows ?? []).map((r) => r.igdb_id as number);
}

const [topRated, shortGames, featuredList, newestCards, myGameCards, calendarDays, browseCats, freeGames] = await Promise.all([
  fetchDiscover({ sort: 'rating', limit: 12 }),
  fetchDiscover({ maxHours: 8, sort: 'rating', limit: 12 }),
  fetchFeaturedList(),
  // Backend computes "newest popular" with proper date filter (last 2 years
  // through 90 days out, cover required, ≥5 ratings) — see getNewestPopular.
  fetchNewest(6),
  // Backend hydrates the user's IGDB IDs into full cards with rating/genres.
  fetchCardsByIds(myGameIds),
  // Calendar = upcoming releases bucketed by date; empty days are skipped.
  fetchCalendar(30),
  // Browse categories — backend returns title/subtitle/href + top-4 covers.
  fetchBrowseCategories(),
  fetchFreeGames(6),
]);

// Fallback to top-rated when the user is logged out or has an empty library.
const myGamesRow = myGameCards.length > 0
  ? myGameCards
  : (await fetchCardsByIds(topRated.slice(0, 6).map((g) => g.igdb_id)));

const featured = featuredList[0] ?? null;
const ROTATE_MS = 8000;

// Detail lookup for rows that still come straight from fetchDiscover
// (Top Recommendation thumbnails, Today's Free). Calendar is fully hydrated
// in the backend.
const detailIds = new Set<number>();
for (const g of [...topRated.slice(0, 6), ...shortGames.slice(0, 6)]) {
  detailIds.add(g.igdb_id);
}
const detailEntries = await Promise.all(
  Array.from(detailIds).map(async (id) => [id, await fetchGameDetail(id)] as const)
);
const detailMap = new Map<number, GameDetail | null>(detailEntries);

function ratingOf(g: GameLite) {
  const d = detailMap.get(g.igdb_id);
  if (!d?.rating) return null;
  return Math.round(d.rating) / 10;
}
function genresOf(g: GameLite): string[] {
  return detailMap.get(g.igdb_id)?.genres?.slice(0, 2) ?? [];
}
function hoursOf(g: GameLite): number | null {
  const h = detailMap.get(g.igdb_id)?.hltb?.main;
  return typeof h === 'number' ? Math.round(h) : null;
}

// Calendar columns come straight from the backend already bucketed and
// date-sorted. Empty days are pre-filtered server-side.
const calendarCols = calendarDays;

// Browse categories come from the backend (each carries its top-4 cover URLs).
const categories = browseCats;
---

<Layout>
  <div class="page">
    <Nav />
    <main>
      <!-- Top Recommendation -->
      <section class="section">
        <header class="section-head">
          <h2>Top Recommendation</h2>
          <button class="cal-view-all" type="button" data-featured-randomize>
            <svg class="dice-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="3" stroke="currentColor" stroke-width="1.8"/>
              <circle cx="8" cy="8" r="1.4" fill="currentColor"/>
              <circle cx="16" cy="8" r="1.4" fill="currentColor"/>
              <circle cx="12" cy="12" r="1.4" fill="currentColor"/>
              <circle cx="8" cy="16" r="1.4" fill="currentColor"/>
              <circle cx="16" cy="16" r="1.4" fill="currentColor"/>
            </svg>
            Randomize
          </button>
        </header>

        {featured && (
          <article class="hero" data-featured-hero style={`background-image: url(${featured.background_url});`}>
            <div class="hero-overlay" aria-hidden="true"></div>
            <div class="hero-content">
              <div class="hero-product">
                <div class="hero-cover">
                  <img data-hero-cover src={featured.cover_url ?? ''} alt={featured.name} loading="eager" />
                </div>
                <div class="hero-info">
                  <img
                    class="hero-logo"
                    data-hero-logo
                    src={featured.title_logo_url}
                    alt={featured.name}
                    style={featured.title_logo_url ? '' : 'display:none'}
                  />
                  <h3
                    class="hero-name"
                    data-hero-name
                    style={featured.title_logo_url ? 'display:none' : ''}
                  >{featured.name}</h3>
                  <p class="hero-blurb" data-hero-blurb>{featured.blurb}</p>
                  <div class="hero-stats">
                    <div class="stat">
                      <span class="stat-value" data-hero-rating-value>{featured.rating.value}</span>
                      <span class="stat-label" data-hero-rating-source>{featured.rating.source}</span>
                    </div>
                    <div class="stat">
                      <span class="stat-value" data-hero-hltb-value>{featured.hltb.value}</span>
                      <span class="stat-label" data-hero-hltb-label>{featured.hltb.label}</span>
                    </div>
                    <div class="stat">
                      <div class="platform-row" data-hero-platforms>
                        {featured.platforms.map((p) => (
                          <span class={`platform-icon p-${p.key}`} aria-label={p.label}>
                            {p.key === 'windows' && (
                              <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M3 5.5L11 4.3v7.2H3V5.5zm0 13L11 19.7v-7.2H3v6zm9-14.4L21 3v8.5h-9V4.1zm0 15.8L21 21v-8.5h-9v7.4z"/></svg>
                            )}
                            {p.key === 'playstation' && (
                              <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M9.5 3v15.6l3.2 1V8.3c0-.7.3-1.2.9-1.2.7 0 1 .7 1 1.4v4.8c2-.9 4.4-1.7 4.4-4.8C19 4 14.9 2.9 9.5 3zM3.4 18.6c-1.4-.4-1.6-1.2 0-1.8L9 14.8v2.6L5 18.9c-.5.2-.6.5 0 .7L9 18v2.4l-1.1.2c-1.5.3-3.2.2-4.5-.2-1.5-.5-1.7-1.3 0-1.8zm17.2-2.6c1.5.4 1.8 1.2.3 1.7l-5.4 1.9V17l4-1.4c.5-.2.6-.4 0-.6l-4-1.4v-1.7l5.1 1.7z"/></svg>
                            )}
                            {p.key === 'xbox' && (
                              <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M12 2C6.5 2 2 6.5 2 12c0 2 .6 3.9 1.6 5.4-.1-1.9 2.8-6.4 6.1-9.5C7.2 6.4 5.2 5.7 4.2 5.7c-.3 0-.5.1-.7.2C5.3 3.5 8.5 2 12 2zm0 20c5.5 0 10-4.5 10-10 0-2-.6-3.9-1.6-5.4.1 1.9-2.8 6.4-6.1 9.5 2.5 1.5 4.5 2.2 5.5 2.2.3 0 .5-.1.7-.2C18.7 20.5 15.5 22 12 22zm0-6.2c-1.5-1.5-5.7-7.7-4.8-8.6 1-1 4.8 2 4.8 2s3.8-3 4.8-2c.9.9-3.3 7.1-4.8 8.6z"/></svg>
                            )}
                          </span>
                        ))}
                        {featured.extra_platform_count > 0 && (
                          <span class="platform-more" data-hero-platform-more>+{featured.extra_platform_count}</span>
                        )}
                      </div>
                      <span class="stat-label">Available on</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="hero-actions">
                <a class="btn-wishlist" data-hero-link href={`/games/${featured.igdb_id}`}>
                  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
                  <span>Add to Wishlist</span>
                </a>
                <button class="btn-fav" type="button" aria-label="Favorite">
                  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" d="M12 17.3L18.2 21l-1.6-7.2L22 9.2l-7.4-.6L12 2 9.4 8.6 2 9.2l5.4 4.6L5.8 21z"/></svg>
                </button>
              </div>
            </div>
          </article>
        )}

        {featuredList.length > 1 && (
          <div class="carousel" data-featured-carousel data-rotate-ms={ROTATE_MS}>
            {featuredList.map((g, i) => (
              <button
                type="button"
                class={`carousel-item${i === 0 ? ' active' : ''}`}
                data-carousel-item
                data-index={i}
                aria-label={g.name}
              >
                {g.cover_url && (
                  <img class="carousel-cover" src={g.cover_url} alt="" loading="lazy" />
                )}
                {g.background_url && (
                  <img class="carousel-art" src={g.background_url} alt="" loading="lazy" />
                )}
                <div class="carousel-shade" aria-hidden="true"></div>
                <div class="carousel-label">
                  {g.title_logo_url ? (
                    <img class="carousel-logo" src={g.title_logo_url} alt={g.name} />
                  ) : (
                    <span class="carousel-name">{g.name}</span>
                  )}
                </div>
                <span class="carousel-progress" aria-hidden="true"></span>
              </button>
            ))}
          </div>
        )}

        <script is:inline type="application/json" data-featured-data set:html={JSON.stringify(featuredList)}></script>
      </section>

      <!-- Games in your list -->
      <CardRowSection
        title="Games in your list"
        href="/my-games"
        items={myGamesRow}
      />

      <!-- Browse Games based on -->
      <section class="section">
        <header class="section-head">
          <h2>Browse Games based on</h2>
        </header>
        <div class="cat-grid">
          {categories.map((c) => (
            <a class="cat-card" href={c.href}>
              <div class="cat-strip" aria-hidden="true">
                {c.covers.slice(0, 4).map((url) => (
                  <div class="cat-strip-cell">
                    <img src={url} alt="" loading="lazy" />
                  </div>
                ))}
                {c.covers.length < 4 && Array.from({ length: 4 - c.covers.length }).map(() => (
                  <div class="cat-strip-cell cat-strip-empty"></div>
                ))}
              </div>
              <div class="cat-shade" aria-hidden="true"></div>
              <div class="cat-body">
                <h4>{c.title}</h4>
                <p>{c.subtitle}</p>
                <span class="cat-browse-btn">Browse</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Newest Games -->
      <CardRowSection
        title="Newest Games"
        href="/browse?sort=release_date"
        items={newestCards}
      />

      <!-- Games Calendar (v2 polish — remove `cal-v2` to revert to original design) -->
      <section class="section cal-section cal-v2">
        <header class="cal-head">
          <h2>Games Calendar</h2>
          <div class="cal-controls">
            <div class="cal-nav" role="group" aria-label="Scroll calendar">
              <button class="cal-nav-btn" type="button" data-cal-prev aria-label="Previous">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button class="cal-nav-btn cal-nav-divide" type="button" data-cal-next aria-label="Next">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <a class="cal-view-all" href="/browse?sort=release_date">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.8"/>
                <path d="M8 3v4M16 3v4M3 10h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
              View All Calendar list
            </a>
          </div>
        </header>

        <div class="cal-scroll-wrap">
          <div class="cal-scroll" data-cal-scroll>
            {calendarCols.map((col) => {
              const total = col.games.length;
              // ≤4 games: show all cards (no +more). >4 games: show 3 + a "+N more" card.
              const display = total > 4 ? col.games.slice(0, 3) : col.games.slice(0, 4);
              const overflow = total - display.length;
              const monthNice = col.month.charAt(0) + col.month.slice(1).toLowerCase();
              return (
                <div class="cal-day-col" data-count={total}>
                  <div class="cal-day-head">
                    <div class="cal-day-date">{col.day} {col.month}</div>
                    <div class="cal-day-meta">
                      <span>{col.weekday}</span>
                      <span class="cal-dot">•</span>
                      <span>{col.games.length} {col.games.length === 1 ? 'Game' : 'Games'}</span>
                    </div>
                  </div>
                  <div class="cal-day-line"></div>
                  <div class="cal-day-grid">
                    {display.map((g) => (
                      <article class="cal-game">
                        <a class="cal-game-link" href={`/games/${g.igdb_id}`} aria-label={g.name}>
                          {g.hero_url && <img class="cal-game-bg" src={g.hero_url} alt="" aria-hidden="true" />}
                          <div class="cal-game-shade" aria-hidden="true"></div>
                          <div class="cal-game-inner">
                            <div class="cal-game-cover">
                              {g.cover_url ? (
                                <img src={g.cover_url} alt={g.name} loading="lazy" />
                              ) : (
                                <div class="cover-fallback"></div>
                              )}
                            </div>
                            <div class="cal-game-info">
                              <div class="cal-game-title">{g.name}</div>
                              <div class="cal-game-plats">
                                <div class="cal-plat-icons">
                                  <span class="cal-plat" aria-label="Windows">
                                    <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"><path fill="currentColor" d="M3 5.5L11 4.3v7.2H3V5.5zm0 13L11 19.7v-7.2H3v6zm9-14.4L21 3v8.5h-9V4.1zm0 15.8L21 21v-8.5h-9v7.4z"/></svg>
                                  </span>
                                  <span class="cal-plat" aria-label="PlayStation">
                                    <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"><path fill="currentColor" d="M9.5 3v15.6l3.2 1V8.3c0-.7.3-1.2.9-1.2.7 0 1 .7 1 1.4v4.8c2-.9 4.4-1.7 4.4-4.8C19 4 14.9 2.9 9.5 3zM3.4 18.6c-1.4-.4-1.6-1.2 0-1.8L9 14.8v2.6L5 18.9c-.5.2-.6.5 0 .7L9 18v2.4l-1.1.2c-1.5.3-3.2.2-4.5-.2-1.5-.5-1.7-1.3 0-1.8zm17.2-2.6c1.5.4 1.8 1.2.3 1.7l-5.4 1.9V17l4-1.4c.5-.2.6-.4 0-.6l-4-1.4v-1.7l5.1 1.7z"/></svg>
                                  </span>
                                  <span class="cal-plat" aria-label="Xbox">
                                    <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true"><path fill="currentColor" d="M12 2C6.5 2 2 6.5 2 12c0 2 .6 3.9 1.6 5.4-.1-1.9 2.8-6.4 6.1-9.5C7.2 6.4 5.2 5.7 4.2 5.7c-.3 0-.5.1-.7.2C5.3 3.5 8.5 2 12 2zm0 20c5.5 0 10-4.5 10-10 0-2-.6-3.9-1.6-5.4.1 1.9-2.8 6.4-6.1 9.5 2.5 1.5 4.5 2.2 5.5 2.2.3 0 .5-.1.7-.2C18.7 20.5 15.5 22 12 22zm0-6.2c-1.5-1.5-5.7-7.7-4.8-8.6 1-1 4.8 2 4.8 2s3.8-3 4.8-2c.9.9-3.3 7.1-4.8 8.6z"/></svg>
                                  </span>
                                  <span class="cal-plat-more">+2</span>
                                </div>
                                <div class="cal-plat-label">Available on</div>
                              </div>
                              <div class="cal-game-tags">
                                {(g.genres.length ? g.genres : ['Adventure', 'Action']).slice(0, 2).map((t) => (
                                  <span class="cal-tag">{t}</span>
                                ))}
                              </div>
                            </div>
                          </div>
                        </a>
                        <button class="cal-wishlist" type="button" aria-label={`Add ${g.name} to wishlist`} data-wishlist data-igdb-id={g.igdb_id}>
                          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                            <path d="M6 4h12a1 1 0 0 1 1 1v15.382a.5.5 0 0 1-.724.447L12 17.5l-6.276 3.329A.5.5 0 0 1 5 20.382V5a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                          </svg>
                        </button>
                      </article>
                    ))}
                    {overflow > 0 && (
                      <a class="cal-more" href={`/browse?sort=release_date`}>
                        <div class="cal-more-thumbs">
                          {col.games.slice(display.length, display.length + 2).map((g) => (
                            g.cover_url ? <img src={g.cover_url} alt="" aria-hidden="true" /> : <div class="cover-fallback"></div>
                          ))}
                        </div>
                        <div class="cal-more-body">
                          <div class="cal-more-title">
                            +{overflow} more
                            <span class="cal-more-sub">games on {col.day} {monthNice}</span>
                          </div>
                          <span class="cal-more-btn">View All List</span>
                        </div>
                      </a>
                    )}
                  </div>
                  <div class="cal-day-line cal-day-line--bottom"></div>
                </div>
              );
            })}
          </div>
          <div class="cal-fade" aria-hidden="true"></div>
        </div>
      </section>

      <!-- Today's Free Game list -->
      <CardRowSection
        title="Today's Free Game list"
        href="/browse"
        items={freeGames.map((fg) => ({
          igdb_id: fg.id,
          name: fg.title,
          slug: '',
          cover_url: fg.thumbnail || fg.image,
          year: null,
          genres: fg.platforms?.slice(0, 3) ?? [],
          worth: fg.worth && fg.worth !== 'N/A' ? fg.worth : null,
          href: fg.url,
        }))}
      />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="foot-brand">
          <div class="brand"><span class="logo" aria-hidden="true">▤</span> Yourshelf</div>
          <p>The first hub end-to-end analytics service for the site, designed to work with enterprises of various levels and business segments.</p>
          <p class="muted">© 2025 — Yourshelf</p>
        </div>
        <div class="foot-col">
          <h5>Open Account</h5>
          <a href="/signup">Discover</a>
          <a href="/browse">Design</a>
          <a href="/search">UI conditioning</a>
          <a href="/login">Installation</a>
        </div>
        <div class="foot-col">
          <h5>Info</h5>
          <a href="#">About us</a>
          <a href="#">Terms & Conditions</a>
          <a href="#">Privacy Policy</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  :root {
    --bg: #0a0c10;
    --bg-2: #0e1014;
    --surface: #14171d;
    --surface-2: #181c24;
    --border: #1f242b;
    --text: #e6e8eb;
    --muted: #8a93a0;
    --accent: #6366f1;
    --accent-2: #a78bfa;
  }
  html, body { background: var(--bg); color: var(--text); }
  body {
    margin: 0;
    font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  *, *::before, *::after { box-sizing: border-box; }
  h1, h2, h3, h4, h5 { font-family: inherit; letter-spacing: -0.018em; }
</style>

<style>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  main { flex: 1; max-width: 1240px; margin: 0 auto; width: 100%; padding: 72px 2.5rem 4rem; }

  .section { margin-bottom: 72px; }
  .section-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1rem; gap: 1rem;
  }
  .section-head h2 {
    margin: 0;
    color: white;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.6px;
  }
  .head-actions { display: inline-flex; gap: 0.5rem; align-items: center; }
  .ghost-btn {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: transparent; color: var(--muted); border: 1px solid var(--border);
    padding: 0.4rem 0.75rem; border-radius: 8px; font: inherit; font-size: 0.78rem;
    cursor: pointer; text-decoration: none;
  }
  .ghost-btn:hover { color: var(--text); border-color: #2a3038; }

  /* Hero — Top Recommendation */
  .hero {
    position: relative; border-radius: 24px; overflow: hidden;
    background-color: #0f1218;
    background-size: cover; background-position: center;
    height: 420px;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.47);
    border-radius: 24px;
    pointer-events: none;
  }
  .hero-content {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 12px;
    align-items: flex-start; justify-content: flex-end;
    padding: 36px 24px;
    height: 100%;
  }
  .hero-product { display: flex; gap: 16px; align-items: flex-end; }
  .hero-cover {
    width: 150px; height: 225px; flex-shrink: 0;
    border-radius: 7.5px; overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.45);
  }
  .hero-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cover-fallback { width: 100%; height: 100%; background: linear-gradient(135deg, #1a1f26, #11151a); }
  .hero-info { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .hero-logo {
    height: 52px; width: auto; display: block;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.55));
  }
  .hero-blurb {
