  /* Per-game card inside a day column.
     - 12px corner radius (matches +more card and the rest of the page).
     - `isolation: isolate` + `will-change: transform` force a fresh stacking
       context so the bg image is clipped on the GPU layer, no corner bleed. */
  .cal-game {
    position: relative;
    height: 131px;
    border-radius: 12px;
    overflow: hidden;
    isolation: isolate;
    background: #16161a;
    text-decoration: none; color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    will-change: transform;
  }
  .cal-game:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.45);
  }
  .cal-game-bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    pointer-events: none;
    z-index: 0;
  }
  .cal-game-shade {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(10, 10, 12, 0.78) 0%, rgba(10, 10, 12, 0.82) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .cal-game-inner {
    position: relative; z-index: 2;
    display: flex; gap: 12px;
    padding: 12px;
    height: 100%;
    box-sizing: border-box;
    align-items: center;
  }
  .cal-game-cover {
    width: 107px; height: 107px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.35);
  }
  .cal-game-cover img,
  .cal-game-cover .cover-fallback {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .cal-game-info {
    display: flex; flex-direction: column;
    gap: 8px;
    align-items: flex-start;
    flex: 1; min-width: 0;
  }
  .cal-game-title {
    color: white;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.2px;
    width: 100%;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .cal-game-plats { display: flex; flex-direction: column; gap: 3px; align-items: flex-start; }
  .cal-plat-icons { display: flex; gap: 6px; align-items: center; }
  .cal-plat {
    display: inline-flex; align-items: center; justify-content: center;
