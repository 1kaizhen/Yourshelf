  /* Browse Games based on — Figma node 100:4474 */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .cat-card {
    position: relative;
    aspect-ratio: 360 / 223;
    border-radius: 12px;
    overflow: hidden;
    background: #1c1c1c;
    text-decoration: none;
    color: var(--text);
    isolation: isolate;
    display: block;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    will-change: transform;
  }
  .cat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.5);
  }

  /* 4 portrait covers as a flush strip across the top of the card. */
  .cat-strip {
    position: absolute; inset: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    z-index: 0;
  }
  .cat-strip-cell {
    position: relative;
    overflow: hidden;
    background: #111;
  }
  .cat-strip-cell img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .cat-strip-empty {
    background: linear-gradient(135deg, #1a1a1a, #131313);
  }

  /* Gradient overlay — translucent at top, solid black at ~62% down. */
  .cat-shade {
    position: absolute; inset: 0;
    z-index: 1;
    background: linear-gradient(178.98deg, rgba(0, 0, 0, 0.4) 1.43%, rgb(0, 0, 0) 62.7%);
  }

  /* Title + subtitle + Browse button, bottom-left. */
  .cat-body {
    position: absolute;
    left: 20px; right: 20px; bottom: 18px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }
  .cat-body h4 {
    margin: 0;
    color: white;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.4;
  }
  .cat-body p {
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.42px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cat-browse-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #851dd5;
    border: 0.9px solid rgba(255, 255, 255, 0.18);
    color: white;
    padding: 9px 14px;
    border-radius: 7.1px;
    font-size: 14.2px;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 4px;
    transition: background 0.15s ease, box-shadow 0.15s ease;
  }
  .cat-card:hover .cat-browse-btn {
    background: #9528ee;
    box-shadow: 0 6px 16px rgba(133, 29, 213, 0.45);
  }

  /* Footer */
  .footer { background: var(--bg-2); border-top: 1px solid var(--border); padding: 2.5rem 2.5rem 2rem; }
  .footer-inner {
    max-width: 1240px; margin: 0 auto;
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem;
  }
  .foot-brand .brand { display: inline-flex; align-items: center; gap: 0.4rem; font-weight: 700; margin-bottom: 0.75rem; }
  .foot-brand .logo { color: var(--accent-2); }
  .foot-brand p { color: var(--muted); font-size: 0.82rem; line-height: 1.6; max-width: 38ch; margin: 0 0 0.6rem; }
  .foot-brand .muted { font-size: 0.78rem; }
  .foot-col h5 { margin: 0 0 0.9rem; font-size: 0.78rem; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; }
  .foot-col a { display: block; color: #b6bcc6; text-decoration: none; font-size: 0.85rem; margin-bottom: 0.55rem; }
  .foot-col a:hover { color: var(--text); }

  /* Responsive — desktop & down */
  @media (max-width: 1100px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .thumb-strip { grid-template-columns: repeat(6, 1fr); }
  }
  @media (max-width: 900px) {
    main { padding: 1.25rem 1.25rem 3rem; }
    .hero-cover { width: 120px; height: 160px; }
    .hero-logo { height: 42px; }
    .cal-day-grid { grid-template-columns: 1fr; }
    .cal-day-col { flex-basis: 348px; }
    .thumb-strip { grid-template-columns: repeat(5, 1fr); }
  }
  @media (max-width: 640px) {
    .cat-grid { grid-template-columns: 1fr; }
    .hero-product { flex-direction: column; align-items: flex-start; }
    .hero-stats { width: auto; flex-wrap: wrap; }
    .footer-inner { grid-template-columns: 1fr; }
    .thumb-strip { grid-template-columns: repeat(4, 1fr); }
  }
</style>

<script>
  type FeaturedPlatform = { key: string; label: string };
  type FeaturedCard = {
    igdb_id: number;
    name: string;
    slug: string;
    cover_url: string | null;
    background_url: string;
    title_logo_url: string;
    blurb: string;
    rating: { value: string; source: string };
    hltb: { value: string; label: string };
    platforms: FeaturedPlatform[];
    extra_platform_count: number;
  };

  const dataEl = document.querySelector<HTMLScriptElement>('script[data-featured-data]');
  const carousel = document.querySelector<HTMLDivElement>('[data-featured-carousel]');
  const hero = document.querySelector<HTMLElement>('[data-featured-hero]');

  if (dataEl && carousel && hero) {
    let list = JSON.parse(dataEl.textContent || '[]') as FeaturedCard[];
    const rotateMs = Number(carousel.dataset.rotateMs || '8000');
    carousel.style.setProperty('--rotate-duration', `${rotateMs}ms`);
    let items = Array.from(carousel.querySelectorAll<HTMLButtonElement>('[data-carousel-item]'));
    let activeIndex = 0;
    let timer: number | undefined;

    const heroLogo = hero.querySelector<HTMLImageElement>('[data-hero-logo]');
    const heroName = hero.querySelector<HTMLElement>('[data-hero-name]');
    const heroCover = hero.querySelector<HTMLImageElement>('[data-hero-cover]');
    const heroBlurb = hero.querySelector<HTMLElement>('[data-hero-blurb]');
    const heroRatingValue = hero.querySelector<HTMLElement>('[data-hero-rating-value]');
    const heroRatingSource = hero.querySelector<HTMLElement>('[data-hero-rating-source]');
    const heroHltbValue = hero.querySelector<HTMLElement>('[data-hero-hltb-value]');
    const heroHltbLabel = hero.querySelector<HTMLElement>('[data-hero-hltb-label]');
    const heroLink = hero.querySelector<HTMLAnchorElement>('[data-hero-link]');

    function updateHero(card: FeaturedCard) {
      hero!.style.backgroundImage = `url(${card.background_url})`;

      if (card.title_logo_url) {
        if (heroLogo) {
          heroLogo.src = card.title_logo_url;
          heroLogo.alt = card.name;
          heroLogo.style.display = '';
        }
        if (heroName) heroName.style.display = 'none';
      } else {
        if (heroLogo) heroLogo.style.display = 'none';
        if (heroName) {
          heroName.textContent = card.name;
          heroName.style.display = '';
        }
      }

      if (heroCover && card.cover_url) {
        heroCover.src = card.cover_url;
        heroCover.alt = card.name;
      }
      if (heroBlurb) heroBlurb.textContent = card.blurb;
      if (heroRatingValue) heroRatingValue.textContent = card.rating.value;
      if (heroRatingSource) heroRatingSource.textContent = card.rating.source;
      if (heroHltbValue) heroHltbValue.textContent = card.hltb.value;
      if (heroHltbLabel) heroHltbLabel.textContent = card.hltb.label;
      if (heroLink) heroLink.href = `/games/${card.igdb_id}`;
    }

    function setActive(next: number) {
      const idx = ((next % list.length) + list.length) % list.length;
      activeIndex = idx;
      items.forEach((el, i) => {
        const isActive = i === idx;
        el.classList.toggle('active', isActive);
        if (isActive) {
          const bar = el.querySelector<HTMLElement>('.carousel-progress');
          if (bar) {
            bar.style.animation = 'none';
            void bar.offsetWidth;
            bar.style.animation = '';
          }
        }
      });
      updateHero(list[idx]);
      restartTimer();
    }

    function restartTimer() {
      if (timer !== undefined) window.clearTimeout(timer);
      timer = window.setTimeout(() => setActive(activeIndex + 1), rotateMs);
    }

    function bindItemClicks() {
      items.forEach((el, i) => {
        el.addEventListener('click', () => setActive(i));
      });
    }

    // Update an existing carousel item's content in-place. This preserves the
    // Astro scoped CSS attribute (data-astro-cid-...) that's set on the
    // server-rendered nodes — recreating via createElement would lose it and
    // every scoped rule (display, active state, label visibility) would break.
    function updateCarouselItem(btn: HTMLButtonElement, g: FeaturedCard) {
      btn.setAttribute('aria-label', g.name);

      const cover = btn.querySelector<HTMLImageElement>('.carousel-cover');
      if (cover && g.cover_url) cover.src = g.cover_url;
      const art = btn.querySelector<HTMLImageElement>('.carousel-art');
      if (art && g.background_url) art.src = g.background_url;

      const labelEl = btn.querySelector<HTMLElement>('.carousel-label');
      if (labelEl) {
        const logo = labelEl.querySelector<HTMLImageElement>('.carousel-logo');
        const nameSpan = labelEl.querySelector<HTMLElement>('.carousel-name');
        if (g.title_logo_url) {
          if (logo) {
            logo.src = g.title_logo_url;
            logo.alt = g.name;
            logo.style.display = '';
          }
          if (nameSpan) nameSpan.style.display = 'none';
        } else {
          if (logo) logo.style.display = 'none';
          if (nameSpan) {
            nameSpan.textContent = g.name;
            nameSpan.style.display = '';
          }
        }
      }
    }

    function rebuildCarousel(newList: FeaturedCard[]) {
      list = newList;
      const count = Math.min(items.length, newList.length);
      for (let i = 0; i < count; i++) updateCarouselItem(items[i], newList[i]);
      // If the new list is shorter, hide any extra items; if longer, ignore the tail.
      for (let i = count; i < items.length; i++) items[i].style.display = 'none';
      for (let i = 0; i < count; i++) items[i].style.display = '';
      activeIndex = -1; // Force updateHero to run inside setActive even when index is 0.
      setActive(0);
    }

    bindItemClicks();

    restartTimer();

    carousel.addEventListener('mouseenter', () => {
      if (timer !== undefined) window.clearTimeout(timer);
      const active = items[activeIndex]?.querySelector<HTMLElement>('.carousel-progress');
      if (active) active.style.animationPlayState = 'paused';
    });
    carousel.addEventListener('mouseleave', () => {
      const active = items[activeIndex]?.querySelector<HTMLElement>('.carousel-progress');
      if (active) active.style.animationPlayState = 'running';
      restartTimer();
    });

    // ─── Randomize button: reroll Top Recommendations ───
    const randomBtn = document.querySelector<HTMLButtonElement>('[data-featured-randomize]');
    if (randomBtn) {
      const API_BASE = import.meta.env.PUBLIC_API_URL;
      randomBtn.addEventListener('click', async () => {
        if (randomBtn.classList.contains('is-loading')) return;
        randomBtn.classList.add('is-loading');
        try {
          const res = await fetch(`${API_BASE}/api/featured/random?count=7`);
          if (!res.ok) return;
          const { featured } = (await res.json()) as { featured: FeaturedCard[] };
          if (featured && featured.length) rebuildCarousel(featured);
        } catch {
          // Swallow — keep the existing list on failure.
        } finally {
          randomBtn.classList.remove('is-loading');
        }
      });
    }
  }

  // ─── Calendar wishlist toggle ───
  // Currently a client-side toggle only; persistence (Supabase user_games row
  // with status='wishlist') can be wired in later via a POST to the backend.
  document.querySelectorAll<HTMLButtonElement>('[data-wishlist]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      btn.classList.toggle('is-active');
    });
  });

  // ─── Games Calendar prev/next scroll ───
  const calScroll = document.querySelector<HTMLDivElement>('[data-cal-scroll]');
  const calPrev = document.querySelector<HTMLButtonElement>('[data-cal-prev]');
  const calNext = document.querySelector<HTMLButtonElement>('[data-cal-next]');
  if (calScroll && calPrev && calNext) {
    // Advance one day-column at a time so the leftmost visible card just
    // shifts by one — not by a viewport width.
    const cols = () => Array.from(calScroll.querySelectorAll<HTMLElement>('.cal-day-col'));
    const scrollToCol = (i: number) => {
      const list = cols();
      if (list.length === 0) return;
      const target = list[Math.max(0, Math.min(list.length - 1, i))];
      calScroll.scrollTo({ left: target.offsetLeft - calScroll.offsetLeft, behavior: 'smooth' });
    };
    const currentIndex = () => {
      const list = cols();
      const left = calScroll.scrollLeft;
      let best = 0;
      let bestDist = Infinity;
      list.forEach((el, i) => {
        const d = Math.abs(el.offsetLeft - calScroll.offsetLeft - left);
        if (d < bestDist) { bestDist = d; best = i; }
      });
      return best;
    };
    calPrev.addEventListener('click', () => scrollToCol(currentIndex() - 1));
    calNext.addEventListener('click', () => scrollToCol(currentIndex() + 1));
  }
</script>
