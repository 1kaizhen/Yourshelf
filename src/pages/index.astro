  /* ============================================================
     Games Calendar — v2 polish
     Opt-in via `.cal-v2` on the section. Remove the class to
     restore the original calendar design above.
     ============================================================ */
  .cal-v2 .cal-day-grid {
    grid-template-columns: repeat(2, 348px);
    grid-auto-rows: 168px;
    gap: 16px;
    /* Reserve space for a full 2-row grid so days with fewer cards still
       have a consistent bottom edge — the divider line below the grid stays
       at the same vertical position regardless of card count. */
    min-height: calc(168px * 2 + 16px);
    align-content: start;
  }

  /* Compact day columns: 1 game → single card, 2 games → stacked vertically.
     Shrinks the column itself to half-width so empty space doesn't linger. */
  .cal-v2 .cal-day-col[data-count="1"],
  .cal-v2 .cal-day-col[data-count="2"] {
    flex-basis: 348px;
  }
  .cal-v2 .cal-day-col[data-count="1"] .cal-day-grid,
  .cal-v2 .cal-day-col[data-count="2"] .cal-day-grid {
    grid-template-columns: 348px;
  }
  .cal-v2 .cal-day-col[data-count="1"] .cal-day-grid {
    /* Keep the same overall column height as multi-game days so the bottom
       divider doesn't hug a single card. */
    min-height: calc(168px * 2 + 16px);
  }

  /* v2: card is now an <article> wrapper; the link is .cal-game-link, and
     the wishlist button sits as a sibling so we don't nest interactives. */
  .cal-v2 .cal-game {
    position: relative;
    display: block;
    height: 168px;
    border-radius: 14px;
    background: #15151a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    will-change: transform;
  }
  .cal-v2 .cal-game:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: 0 14px 32px rgba(0, 0, 0, 0.5);
