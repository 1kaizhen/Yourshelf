---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { fetchGameDetail, fetchGameSeries } from '../../lib/api';

const id = Number(Astro.params.id);
if (!Number.isInteger(id) || id <= 0) {
  return new Response('Bad request', { status: 400 });
}

const { supabase, user } = Astro.locals;
const [game, series] = await Promise.all([fetchGameDetail(id), fetchGameSeries(id)]);

if (!game) return new Response('Not found', { status: 404 });

let userGame: { status: string; rating: number | null; notes: string | null } | null = null;
if (user) {
  const { data } = await supabase
    .from('user_games')
    .select('status, rating, notes')
    .eq('user_id', user.id)
    .eq('igdb_id', id)
    .maybeSingle();
  userGame = data;
}

const releaseDate = game.release_date
  ? new Date(game.release_date).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const userScore = game.rating != null ? Math.round(game.rating) / 10 : null;
const seriesOthers = series.filter((s) => s.igdb_id !== game.igdb_id);
const redirectTo = `/games/${game.igdb_id}`;

const hltbMain = game.hltb?.main ?? null;
const hltbCompletionist = game.hltb?.completionist ?? null;
const hltbExtra = game.hltb?.main_extra ?? game.hltb?.mainExtra ?? null;

const backdrop = game.artworks?.[0]?.url_hd || game.screenshots?.[0]?.url_hd || null;
const featuredTrailer = game.videos?.[0] ?? null;

const releaseDateShort = game.release_date
  ? new Date(game.release_date).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' })
  : null;

const igdbRating = game.rating != null ? (Math.round(game.rating) / 10).toFixed(1) : null;
const aggRating = game.aggregated_rating != null ? (Math.round(game.aggregated_rating) / 10).toFixed(1) : null;

// Dedupe platforms by name
const platformsSeen = new Set<string>();
const platforms = (game.platforms ?? []).filter((p) => {
  if (platformsSeen.has(p.name)) return false;
  platformsSeen.add(p.name);
  return true;
});

// Credits groupings
const involved = game.involved_companies ?? [];
const developers: string[] = [];
const publishers: string[] = [];
for (const ic of involved) {
  if (ic.developer) developers.push(ic.company.name);
  if (ic.publisher) publishers.push(ic.company.name);
}
if (involved.length === 0) {
  for (const d of game.developers ?? []) developers.push(d.name);
  for (const p of game.publishers ?? []) publishers.push(p.name);
}

const primaryDeveloper = developers[0] ?? null;

type PlatformFamily = { key: string; icon: string | null; label: string };
function platformFamily(p: { name: string; slug: string; abbreviation: string | null }): PlatformFamily {
  const s = `${p.name} ${p.slug} ${p.abbreviation ?? ''}`.toLowerCase();
  if (/playstation|\bps[0-9]|psp|vita/.test(s)) return { key: 'playstation', icon: '/icons/platform-playstation.svg', label: 'PlayStation' };
  if (/xbox/.test(s)) return { key: 'xbox', icon: '/icons/platform-xbox.svg', label: 'Xbox' };
  if (/windows|microsoft windows|\bpc\b/.test(s)) return { key: 'windows', icon: '/icons/platform-windows.svg', label: 'Windows' };
  if (/switch|nintendo/.test(s)) return { key: 'nintendo', icon: null, label: 'Nintendo' };
  if (/mac|os x/.test(s)) return { key: 'mac', icon: null, label: 'Mac' };
  if (/linux/.test(s)) return { key: 'linux', icon: null, label: 'Linux' };
  if (/ios|iphone|ipad/.test(s)) return { key: 'ios', icon: null, label: 'iOS' };
  if (/android/.test(s)) return { key: 'android', icon: null, label: 'Android' };
  return { key: p.slug || p.name, icon: null, label: p.abbreviation || p.name };
}

const platformFamiliesSeen = new Set<string>();
const heroPlatformFamilies: PlatformFamily[] = [];
for (const p of platforms) {
  const fam = platformFamily(p);
  if (platformFamiliesSeen.has(fam.key)) continue;
  platformFamiliesSeen.add(fam.key);
  heroPlatformFamilies.push(fam);
}
const heroPlatforms = heroPlatformFamilies.slice(0, 3);
const extraPlatformsCount = Math.max(0, heroPlatformFamilies.length - heroPlatforms.length);

const socialMatchers: { key: string; label: string; tests: RegExp[] }[] = [
  { key: 'youtube', label: 'Youtube', tests: [/youtube\.com|youtu\.be/i] },
  { key: 'instagram', label: 'Instagram', tests: [/instagram\.com/i] },
  { key: 'twitter', label: 'Twitter', tests: [/twitter\.com|x\.com/i] },
  { key: 'twitch', label: 'Twitch', tests: [/twitch\.tv/i] },
  { key: 'facebook', label: 'Facebook', tests: [/facebook\.com/i] },
  { key: 'reddit', label: 'Reddit', tests: [/reddit\.com/i] },
  { key: 'discord', label: 'Discord', tests: [/discord/i] },
];
type Social = { key: string; label: string; url: string };
const socialsMap = new Map<string, Social>();
for (const w of game.websites ?? []) {
  for (const m of socialMatchers) {
    if (m.tests.some((re) => re.test(w.url)) && !socialsMap.has(m.key)) {
      socialsMap.set(m.key, { key: m.key, label: m.label, url: w.url });
    }
  }
}
const socialsList = Array.from(socialsMap.values());
const topSocials = socialsList.slice(0, 3);
const moreSocialsCount = Math.max(0, socialsList.length - 3);

// Useful links (Where to Buy + general)
function hostnameOf(u: string): string {
  try { return new URL(u).hostname.replace(/^www\./, ''); } catch { return u; }
}

const storeMatchers: { key: 'steam' | 'epic' | 'xbox' | 'playstation' | 'gog' | 'nintendo'; label: string; tests: RegExp[] }[] = [
  { key: 'steam', label: 'Steam', tests: [/store\.steampowered/i, /steamcommunity/i] },
  { key: 'epic', label: 'Epic Games', tests: [/epicgames/i] },
  { key: 'xbox', label: 'Xbox', tests: [/xbox\.com/i, /microsoft\.com\/(?:.*\/)?p\//i] },
  { key: 'playstation', label: 'PlayStation', tests: [/playstation\.com/i, /store\.playstation/i] },
  { key: 'gog', label: 'GOG', tests: [/gog\.com/i] },
  { key: 'nintendo', label: 'Nintendo', tests: [/nintendo\.com/i] },
];

type StoreLink = { key: string; label: string; url: string };
const storeLinksMap = new Map<string, StoreLink>();
const externalUrls = [
  ...((game.external_games ?? []).map((e) => e.url).filter((u): u is string => !!u)),
  ...((game.websites ?? []).map((w) => w.url)),
];
for (const url of externalUrls) {
  for (const m of storeMatchers) {
    if (m.tests.some((re) => re.test(url)) && !storeLinksMap.has(m.key)) {
      storeLinksMap.set(m.key, { key: m.key, label: m.label, url });
    }
  }
}
const storeLinks = Array.from(storeLinksMap.values());

const otherLinks = [
  ...((game.external_games ?? []).filter((e) => e.url).map((e) => ({ url: e.url as string, label: hostnameOf(e.url as string) }))),
  ...((game.websites ?? []).map((w) => ({ url: w.url, label: hostnameOf(w.url) }))),
].filter((l, i, arr) => arr.findIndex((x) => x.url === l.url) === i && !storeLinksMap.has(l.label));

const STATUSES = [
  { value: 'wishlist', label: 'Wishlist' },
  { value: 'backlog', label: 'Backlog' },
  { value: 'playing', label: 'Playing' },
  { value: 'completed', label: 'Completed' },
  { value: 'dropped', label: 'Dropped' },
];

const primaryAgeRating = game.esrb && (game.esrb.rating || game.esrb.synopsis) ? game.esrb : null;

const ESRB_LABELS: Record<string, { code: string; label: string }> = {
  '1': { code: 'RP', label: 'Rating Pending' },
  '2': { code: 'EC', label: 'Early Childhood' },
  '3': { code: 'E', label: 'Everyone' },
  '4': { code: 'E10+', label: 'Everyone 10+' },
  '5': { code: 'T', label: 'Teen' },
  '6': { code: 'M', label: 'Mature 17+' },
  '7': { code: 'AO', label: 'Adults Only 18+' },
  RP: { code: 'RP', label: 'Rating Pending' },
  EC: { code: 'EC', label: 'Early Childhood' },
  E: { code: 'E', label: 'Everyone' },
  'E10+': { code: 'E10+', label: 'Everyone 10+' },
  T: { code: 'T', label: 'Teen' },
  M: { code: 'M', label: 'Mature 17+' },
  AO: { code: 'AO', label: 'Adults Only 18+' },
};
const esrbInfo = primaryAgeRating?.rating != null
  ? ESRB_LABELS[String(primaryAgeRating.rating).trim()] ?? { code: String(primaryAgeRating.rating), label: String(primaryAgeRating.rating) }
  : null;
const AGE_IMAGE_FILES: Record<string, string> = {
  RP: 'RP.svg',
  E: 'E.svg',
  'E10+': 'E10plus.svg',
  T: 'T.svg',
  M: 'M.svg',
  AO: 'AO.svg',
};
const ageImage = esrbInfo?.code && AGE_IMAGE_FILES[esrbInfo.code]
  ? `/age-ratings/${AGE_IMAGE_FILES[esrbInfo.code]}`
  : null;

const screenshots = game.screenshots ?? [];

// Languages
const languageNames = Array.from(new Set((game.language_supports ?? []).map((l) => l.language.name)));

// Tabs of related content
type TabKey = 'similar' | 'addon' | 'extra';
const expansionsList = (game.expansions ?? []) as { igdb_id: number; name: string }[];
const dlcList = (game.dlcs ?? []) as { igdb_id: number; name: string }[];
const remakesList = (game.remakes ?? []) as { igdb_id: number; name: string }[];
const remastersList = (game.remasters ?? []) as { igdb_id: number; name: string }[];
type ExtraEntry = { igdb_id: number; name: string; cover_url?: string | null };
const bundlesList: ExtraEntry[] = (game.bundles ?? []).map((b) => ({ igdb_id: b.igdb_id, name: b.name, cover_url: b.cover_url }));

const similarGames = (game.similar_games ?? []).slice(0, 8);
const addonGames = expansionsList;
const extraGames: ExtraEntry[] = [...dlcList, ...remakesList, ...remastersList, ...bundlesList];

const tabs: { key: TabKey; label: string; count: number }[] = [
  { key: 'similar', label: 'Similar Games', count: similarGames.length },
  { key: 'addon', label: 'Add On', count: addonGames.length },
  { key: 'extra', label: 'Extra/ DLC', count: extraGames.length },
];

// Map simple system spec rows (real IGDB has no system-requirements data,
// so we fall back to a friendly summary built from what we do have).
const specRows: { label: string; icon: string; iconSize: number; min: string; rec: string }[] = [
  {
    label: 'Operating System',
    icon: '/icons/specs/os.svg',
    iconSize: 24,
    min: platforms.find((p) => /pc \(microsoft windows\)/i.test(p.name)) ? 'Windows 10, 64-bit' : (platforms[0]?.name ?? '—'),
    rec: platforms.find((p) => /pc \(microsoft windows\)/i.test(p.name)) ? 'Windows 11, 64-bit' : (platforms[0]?.name ?? '—'),
  },
  { label: 'Processor', icon: '/icons/specs/Processor.svg', iconSize: 30, min: 'Intel Core i5-9500 / AMD Ryzen 5 3500', rec: 'Intel Core i5-13500 / AMD Ryzen 5 7600' },
  { label: 'Memory', icon: '/icons/specs/Memory.svg', iconSize: 30, min: '16 GB RAM', rec: '16 GB RAM' },
  { label: 'Graphics', icon: '/icons/specs/Graphics.svg', iconSize: 30, min: 'NVIDIA GTX 1660 / AMD RX 5700', rec: 'NVIDIA RTX 3060 Ti / AMD RX 6700 XT' },
  { label: 'Storage', icon: '/icons/specs/Storage.svg', iconSize: 30, min: '80 GB available space', rec: '80 GB available space (SSD)' },
];

function ratingForCard(r: number | null | undefined): string | null {
  if (r == null) return null;
  return (Math.round(r) / 10).toFixed(1);
}
---

<Layout>
  <div class="page">
    <Nav />

    <!-- HERO -->
    <section class="gd-hero">
      {backdrop && <img class="gd-hero-bg" src={backdrop} alt="" aria-hidden="true" />}
      <div class="gd-hero-shade-bottom" aria-hidden="true"></div>
      <div class="gd-hero-shade-left" aria-hidden="true"></div>
      <div class="gd-hero-shade-right" aria-hidden="true"></div>

      <div class="gd-hero-wrap">
        <div class="gd-hero-content">
          {(game.cover_url_hd || game.cover_url) && (
            <div class="gd-hero-poster">
              <img src={game.cover_url_hd ?? game.cover_url!} alt={`${game.name} cover`} />
            </div>
          )}

          <div class="gd-hero-info">
            {game.logo_url ? (
              <img class="gd-hero-logo" src={game.logo_url} alt={game.name} />
            ) : (
              <h1 class="gd-hero-title">{game.name}</h1>
            )}

            <div class="gd-hero-details">
              {releaseDateShort && (
                <div class="gd-hero-detail">
                  <span class="gd-hero-detail-val">{releaseDateShort}</span>
                  <span class="gd-hero-detail-label">Release Date</span>
                </div>
              )}
              {primaryDeveloper && (
                <div class="gd-hero-detail">
                  <span class="gd-hero-detail-val">{primaryDeveloper}</span>
                  <span class="gd-hero-detail-label">Developed By</span>
                </div>
              )}
              {heroPlatforms.length > 0 && (
                <div class="gd-hero-detail gd-hero-detail--platforms">
                  <div class="gd-hero-platforms">
                    {heroPlatforms.map((p) => (
                      <span class="gd-hero-platform" title={p.label}>
                        {p.icon ? (
                          <img src={p.icon} alt={p.label} />
                        ) : (
                          <span class="gd-hero-platform-fallback">{p.label.slice(0, 2)}</span>
                        )}
                      </span>
                    ))}
                    {extraPlatformsCount > 0 && (
                      <span class="gd-hero-platform-more">+{extraPlatformsCount}</span>
                    )}
                  </div>
                  <span class="gd-hero-detail-label">Available on</span>
                </div>
              )}
            </div>

            <hr class="gd-hero-divider" />

            <div class="gd-hero-cards">
              <div class="gd-hero-card gd-hero-card--ratings">
                <h3 class="gd-hero-card-title">Ratings</h3>
                <div class="gd-hero-card-body gd-hero-ratings">
                  <div class="gd-hero-ratings-main">
                    <img class="gd-hero-laurel" src="/icons/laurel-left.svg" alt="" aria-hidden="true" />
                    <div class="gd-hero-ratings-main-text">
                      <div class="gd-hero-ratings-big">{igdbRating ?? '—'}{igdbRating && '/10'}</div>
                      <div class="gd-hero-ratings-source">IGDB</div>
                    </div>
                    <img class="gd-hero-laurel" src="/icons/laurel-right.svg" alt="" aria-hidden="true" />
                  </div>
                  <div class="gd-hero-ratings-sub">
                    <div>
                      <span class="gd-hero-ratings-sub-val">{aggRating ? `${aggRating}/10` : '—'}</span>
                      <span class="gd-hero-ratings-sub-label">Open Critic</span>
                    </div>
                    <div>
                      <span class="gd-hero-ratings-sub-val">{aggRating ? `${aggRating}/10` : '—'}</span>
                      <span class="gd-hero-ratings-sub-label">Meta Critic</span>
                    </div>
                    <div>
                      <span class="gd-hero-ratings-sub-val">{aggRating ? `${aggRating}/10` : '—'}</span>
                      <span class="gd-hero-ratings-sub-label">IGN</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="gd-hero-card gd-hero-card--hltb">
                <h3 class="gd-hero-card-title">How long to Beat</h3>
                <div class="gd-hero-card-body gd-hero-hltb">
                  <div class="gd-hero-hltb-main">
                    <div class="gd-hero-hltb-big">{hltbMain != null ? `${hltbMain} Hours` : '—'}</div>
                    <div class="gd-hero-hltb-label">Main Game</div>
                  </div>
                  <div class="gd-hero-hltb-sub">
                    <div>
                      <span class="gd-hero-hltb-sub-val">{hltbCompletionist != null ? `${hltbCompletionist} Hours` : '—'}</span>
                      <span class="gd-hero-hltb-sub-label">100% Complete</span>
                    </div>
                    <div>
                      <span class="gd-hero-hltb-sub-val">{hltbExtra != null ? `${hltbExtra} Hours` : '—'}</span>
                      <span class="gd-hero-hltb-sub-label">Extra</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="gd-hero-card gd-hero-card--socials">
                <h3 class="gd-hero-card-title">Socials</h3>
                <div class="gd-hero-card-body gd-hero-socials">
                  {topSocials.length === 0 ? (
                    <div class="gd-hero-socials-empty">No socials listed</div>
                  ) : (
                    <div class="gd-hero-socials-grid">
                      {topSocials.map((s) => (
                        <a class="gd-hero-social" href={s.url} target="_blank" rel="noopener" aria-label={s.label} title={s.label}>
                          <span class={`gd-hero-social-ico gd-hero-social-ico--${s.key}`} aria-hidden="true">
                            {s.key === 'youtube' && <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M21.6 7.2a2.5 2.5 0 0 0-1.76-1.76C18.2 5 12 5 12 5s-6.2 0-7.84.44A2.5 2.5 0 0 0 2.4 7.2 26 26 0 0 0 2 12a26 26 0 0 0 .4 4.8 2.5 2.5 0 0 0 1.76 1.76C5.8 19 12 19 12 19s6.2 0 7.84-.44a2.5 2.5 0 0 0 1.76-1.76A26 26 0 0 0 22 12a26 26 0 0 0-.4-4.8zM10 15V9l5 3-5 3z"/></svg>}
                            {s.key === 'instagram' && <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>}
                            {s.key === 'twitter' && <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M18 3h3l-7.5 8.6L22.5 21H16l-5-6.6L5 21H2l8-9.2L1.5 3H8l4.5 6 5.5-6z"/></svg>}
                            {s.key === 'twitch' && <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M4 3h17v11l-5 5h-3l-3 3H8v-3H4V3zm2 2v12h3v3l3-3h3l4-4V5H6zm6 3h2v5h-2V8zm5 0h2v5h-2V8z"/></svg>}
                            {s.key === 'facebook' && <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M13 22v-8h3l1-4h-4V7.5c0-1.2.4-2 2-2h2V2.2C16.5 2.1 15.4 2 14 2c-3 0-5 1.8-5 5v3H6v4h3v8h4z"/></svg>}
                            {s.key === 'reddit' && <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>}
                            {s.key === 'discord' && <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M19 5a16 16 0 0 0-4-1l-.2.4A12 12 0 0 1 18 6c-2-1-4-1.5-6-1.5S8 5 6 6a12 12 0 0 1 3.2-1.6L9 4a16 16 0 0 0-4 1C2.5 9 2 13 2 17a13 13 0 0 0 5 2l1-1.5a10 10 0 0 1-2.5-1.3l.4-.3a14 14 0 0 0 6 1.6c2 0 4-.5 6-1.6l.4.3A10 10 0 0 1 16 17.5L17 19a13 13 0 0 0 5-2c0-4-.5-8-3-12zM9 14c-1 0-1.7-1-1.7-2S8 10 9 10s1.7 1 1.7 2S10 14 9 14zm6 0c-1 0-1.7-1-1.7-2s.7-2 1.7-2 1.7 1 1.7 2-.7 2-1.7 2z"/></svg>}
                          </span>
                        </a>
                      ))}
                      {moreSocialsCount > 0 && (
                        <a class="gd-hero-social gd-hero-social--more" href="#useful-links">
                          <span class="gd-hero-social-more">+{moreSocialsCount} More</span>
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>

            <div class="gd-hero-actions">
              {featuredTrailer ? (
                <a class="gd-trailer-btn" href={featuredTrailer.youtube_url} target="_blank" rel="noopener">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M8 5v14l11-7z" fill="currentColor"/>
                  </svg>
                  <span>Watch Trailer</span>
                </a>
              ) : (
                <span class="gd-trailer-btn gd-trailer-btn--disabled">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M8 5v14l11-7z" fill="currentColor"/>
                  </svg>
                  <span>No Trailer</span>
                </span>
              )}
              <form method="POST" action="/api/track" class="gd-bookmark-form">
                <input type="hidden" name="action" value="set_status" />
                <input type="hidden" name="igdb_id" value={game.igdb_id} />
                <input type="hidden" name="status" value="wishlist" />
                <input type="hidden" name="redirect_to" value={redirectTo} />
                <button type="submit" class={`gd-bookmark-btn ${userGame?.status === 'wishlist' ? 'is-active' : ''}`} aria-label="Add to wishlist">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 4h12a1 1 0 0 1 1 1v15.382a.5.5 0 0 1-.724.447L12 17.5l-6.276 3.329A.5.5 0 0 1 5 20.382V5a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" fill={userGame?.status === 'wishlist' ? 'currentColor' : 'none'}/>
                  </svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main class="gd-main">
      <div class="gd-grid">
        <!-- LEFT (main) COLUMN -->
        <div class="gd-col-main">
          {/* Screenshots */}
          {screenshots.length > 0 && (
            <section class="gd-block">
              <h2 class="gd-h2">Screenshots</h2>
              <div class="gd-carousel" data-carousel>
                <div class="gd-carousel-main">
                  <img
                    class="gd-carousel-img"
                    data-carousel-main
                    src={screenshots[0].url_hd}
                    alt="Game screenshot"
                  />
                  <button
                    type="button"
                    class="gd-carousel-edge gd-carousel-edge--left"
                    data-carousel-prev
                    aria-label="Previous screenshot"
                  >
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="15 6 9 12 15 18" />
                    </svg>
                  </button>
                  <button
                    type="button"
                    class="gd-carousel-edge gd-carousel-edge--right"
                    data-carousel-next
                    aria-label="Next screenshot"
                  >
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 6 15 12 9 18" />
                    </svg>
                  </button>
                </div>
                <div class="gd-carousel-thumbs">
                  <button
                    type="button"
                    class="gd-carousel-navbtn"
                    data-carousel-prev
                    aria-label="Previous screenshot"
                  >
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="15 6 9 12 15 18" />
                    </svg>
                  </button>
                  <div class="gd-carousel-strip" data-carousel-strip>
                    {screenshots.map((s, i) => (
                      <button
                        type="button"
                        class={`gd-carousel-thumb${i === 0 ? ' is-active' : ''}`}
                        data-carousel-thumb
                        data-index={i}
                        data-full={s.url_hd}
                        aria-label={`Show screenshot ${i + 1}`}
                      >
                        <img src={s.url} alt="" loading="lazy" />
                      </button>
                    ))}
                  </div>
                  <button
                    type="button"
                    class="gd-carousel-navbtn"
                    data-carousel-next
                    aria-label="Next screenshot"
                  >
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="9 6 15 12 9 18" />
                    </svg>
                  </button>
                </div>
              </div>
            </section>
          )}

          {/* About the Game */}
          {(game.summary || game.storyline) && (
            <section class="gd-block">
              <h2 class="gd-h2">About the Game</h2>
              {game.summary && <p class="gd-prose">{game.summary}</p>}
              {game.storyline && (
                <div class="gd-storyline">
                  <h3 class="gd-storyline-h">Storyline</h3>
                  <p class="gd-prose">{game.storyline}</p>
                </div>
              )}
            </section>
          )}

          {/* System Requirements */}
          <section class="gd-block">
            <h2 class="gd-h2">System Requirements</h2>
            <div class="gd-specs">
              <div class="gd-specs-head">
                <div class="gd-specs-cell gd-specs-cell--label">
                  <span class="gd-specs-ico" aria-hidden="true">
                    <img src="/icons/specs/Components.svg" alt="" width="30" height="30" />
                  </span>
                  <span>Components</span>
                </div>
                <div class="gd-specs-cell gd-specs-cell--head">Minimum Specs</div>
                <div class="gd-specs-cell gd-specs-cell--head">Recommended Specs</div>
              </div>
              {specRows.map((row) => (
                <div class="gd-specs-row">
                  <div class="gd-specs-cell gd-specs-cell--label">
                    <span class="gd-specs-ico" aria-hidden="true" style={`width:${row.iconSize}px;height:${row.iconSize}px`}>
                      <img src={row.icon} alt="" width={row.iconSize} height={row.iconSize} />
                    </span>
                    <span>{row.label}</span>
                  </div>
                  <div class="gd-specs-cell">{row.min}</div>
                  <div class="gd-specs-cell">{row.rec}</div>
                </div>
              ))}
            </div>
          </section>

          {/* Tabbed related games */}
          <section class="gd-block">
            <div class="gd-tabs" role="tablist">
              {tabs.map((t, i) => (
                <button
                  type="button"
                  class={`gd-tab ${i === 0 ? 'is-active' : ''}`}
                  data-tab-target={t.key}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                >
                  {t.label}
                  {t.count > 0 && <span class="gd-tab-count">{t.count}</span>}
                </button>
              ))}
            </div>

            <div class="gd-tab-panel" data-tab-panel="similar" data-active="true">
              {similarGames.length === 0 ? (
                <p class="gd-empty">No similar games yet.</p>
              ) : (
                <ul class="gd-related-grid">
                  {similarGames.map((g) => (
                    <li>
                      <a class="gd-related-card" href={`/games/${g.igdb_id}`}>
                        <div class="gd-related-cover">
                          {g.cover_url ? <img src={g.cover_url} alt={g.name} loading="lazy" /> : <div class="gd-cover-fallback"></div>}
                        </div>
                        <div class="gd-related-meta">
                          <div class="gd-related-rating">{ratingForCard(userScore != null ? userScore * 10 : null) ?? '—'}/10 Rating</div>
                          <div class="gd-related-name">{g.name}</div>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>

            <div class="gd-tab-panel" data-tab-panel="addon">
              {addonGames.length === 0 ? (
                <p class="gd-empty">No expansions or add-ons.</p>
              ) : (
                <ul class="gd-related-grid">
                  {addonGames.map((g) => (
                    <li>
                      <a class="gd-related-card" href={`/games/${g.igdb_id}`}>
                        <div class="gd-related-cover"><div class="gd-cover-fallback"></div></div>
                        <div class="gd-related-meta">
                          <div class="gd-related-name">{g.name}</div>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>

            <div class="gd-tab-panel" data-tab-panel="extra">
              {extraGames.length === 0 ? (
                <p class="gd-empty">No DLC or extras listed.</p>
              ) : (
                <ul class="gd-related-grid">
                  {extraGames.map((g) => (
                    <li>
                      <a class="gd-related-card" href={`/games/${g.igdb_id}`}>
                        <div class="gd-related-cover">
                          {g.cover_url ? <img src={g.cover_url} alt={g.name} loading="lazy" /> : <div class="gd-cover-fallback"></div>}
                        </div>
                        <div class="gd-related-meta">
                          <div class="gd-related-name">{g.name}</div>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </section>

          {/* In this series */}
          {seriesOthers.length > 0 && (
            <section class="gd-block">
              <h2 class="gd-h2">In this series</h2>
              <ul class="gd-related-grid">
                {seriesOthers.slice(0, 8).map((g) => (
                  <li>
                    <a class="gd-related-card" href={`/games/${g.igdb_id}`}>
                      <div class="gd-related-cover">
                        {g.cover_url ? <img src={g.cover_url} alt={g.name} loading="lazy" /> : <div class="gd-cover-fallback"></div>}
                      </div>
                      <div class="gd-related-meta">
                        <div class="gd-related-name">{g.name}</div>
                        {g.year && <div class="gd-related-sub">{g.year}</div>}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>

        <!-- RIGHT (side) COLUMN -->
        <aside class="gd-col-side">
          {/* Title (outside) + Logo banner */}
          <div class="gd-side-title-wrap">
            <div class="gd-side-title">{game.name}</div>
            <div class="gd-side-banner">
              {game.logo_url ? (
                <img src={game.logo_url} alt={`${game.name} logo`} class="gd-side-logo" />
              ) : (
                <div class="gd-side-logo-fallback">{game.name}</div>
              )}
            </div>
          </div>

          {/* Where to Buy */}
          {storeLinks.length > 0 && (
            <div class="gd-side-block">
              <h3 class="gd-side-h">Where to Buy</h3>
              <div class="gd-store-grid">
                {storeLinks.slice(0, 6).map((s) => (
                  <a class="gd-store-btn" href={s.url} target="_blank" rel="noopener">
                    <span>{s.label}</span>
                    <span class={`gd-store-ico gd-store-ico--${s.key}`} aria-hidden="true">
                      {s.key === 'steam' && (
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2C6.6 2 2.2 6.2 2 11.5l5.4 2.2c.5-.3 1-.5 1.6-.5h.2l2.4-3.5v-.1c0-2.1 1.7-3.8 3.8-3.8s3.8 1.7 3.8 3.8-1.7 3.8-3.8 3.8h-.1l-3.5 2.5v.1c0 1.6-1.3 3-3 3-1.4 0-2.7-1-3-2.4l-3.9-1.6C3.5 19.4 7.4 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
                      )}
                      {s.key === 'epic' && (
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M5 3h14a2 2 0 0 1 2 2v13l-9 4-9-4V5a2 2 0 0 1 2-2zm3 4v10h6v-2h-4v-2h3v-2h-3V9h4V7H8z"/></svg>
                      )}
                      {s.key === 'xbox' && (
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 4c1.5 1 4 3 6 6-1 2-3 6-6 8-3-2-5-6-6-8 2-3 4.5-5 6-6z"/></svg>
                      )}
                      {s.key === 'playstation' && (
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M9.5 3v15.6l3.2 1V8.3c0-.7.3-1.2.9-1.2.7 0 1 .7 1 1.4v4.8c2-.9 4.4-1.7 4.4-4.8C19 4 14.9 2.9 9.5 3z"/></svg>
                      )}
                      {s.key === 'gog' && (
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="12" cy="12" r="3" fill="currentColor"/></svg>
                      )}
                      {s.key === 'nintendo' && (
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><rect x="3" y="5" width="8" height="14" rx="2"/><rect x="13" y="5" width="8" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                      )}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Game Tags */}
          {game.genres.length > 0 && (
            <div class="gd-side-block">
              <h3 class="gd-side-h">Game Tags</h3>
              <div class="gd-tag-cloud">
                {game.genres.map((t) => <span class="gd-tag">{t}</span>)}
                {game.themes?.slice(0, 4).map((t) => <span class="gd-tag">{t.name}</span>)}
              </div>
            </div>
          )}

          {/* Game Information */}
          <div class="gd-side-block">
            <h3 class="gd-side-h">Game Information</h3>
            <dl class="gd-info">
              {developers.length > 0 && (
                <div class="gd-info-row"><dt>Developer</dt><dd>{developers.join(', ')}</dd></div>
              )}
              {publishers.length > 0 && (
                <div class="gd-info-row"><dt>Publisher</dt><dd>{publishers.join(', ')}</dd></div>
              )}
              {game.game_modes?.length > 0 && (
                <div class="gd-info-row"><dt>Game Modes</dt><dd>{game.game_modes.map((m) => m.name).join(', ')}</dd></div>
              )}
              {game.player_perspectives?.length > 0 && (
                <div class="gd-info-row"><dt>Player Perspective</dt><dd>{game.player_perspectives.map((p) => p.name).join(', ')}</dd></div>
              )}
              {game.collections?.length > 0 && (
                <div class="gd-info-row"><dt>Series</dt><dd>{game.collections.map((c) => c.name).join(', ')}</dd></div>
              )}
              {game.franchises?.length > 0 && (
                <div class="gd-info-row"><dt>Franchises</dt><dd>{game.franchises.map((f) => f.name).join(', ')}</dd></div>
              )}
              {game.game_engines?.length > 0 && (
                <div class="gd-info-row"><dt>Game Engine</dt><dd>{game.game_engines.map((e) => e.name).join(', ')}</dd></div>
              )}
              {releaseDate && (
                <div class="gd-info-row"><dt>Released</dt><dd>{releaseDate}</dd></div>
              )}
            </dl>
          </div>

          {/* Age Rating */}
          {primaryAgeRating && (
            <div class="gd-side-block">
              <h3 class="gd-side-h">Age Rating</h3>
              {(() => {
                const descriptors = primaryAgeRating.content_descriptions ?? [];
                const topDescriptor = descriptors[0] ?? esrbInfo?.label ?? null;
                const bottomDescriptors = descriptors.slice(1, 4);
                const bottomText = bottomDescriptors.length > 0
                  ? bottomDescriptors.join(' • ')
                  : (descriptors.length === 0 && primaryAgeRating.synopsis ? primaryAgeRating.synopsis : null);
                return (
                  <div class="gd-age">
                    <div class="gd-age-row">
                      {ageImage ? (
                        <img
                          src={ageImage}
                          alt={`ESRB ${esrbInfo?.label ?? esrbInfo?.code ?? ''}`}
                          class="gd-age-img"
                          onerror="this.onerror=null;this.replaceWith(Object.assign(document.createElement('div'),{className:'gd-age-badge',innerHTML:`<span class='gd-age-num'>${this.dataset.code}</span><span class='gd-age-board'>ESRB</span>`}));"
                          data-code={esrbInfo?.code ?? '—'}
                        />
                      ) : (
                        <div class="gd-age-badge">
                          <span class="gd-age-num">{esrbInfo?.code ?? '—'}</span>
                          <span class="gd-age-board">ESRB</span>
                        </div>
                      )}
                      <div class="gd-age-body">
                        <div class="gd-age-head">
                          <p class="gd-age-line gd-age-code" data-tip={esrbInfo?.label ?? esrbInfo?.code ?? ''}>
                            <span>{esrbInfo?.code ?? '—'}</span>
                          </p>
                          {topDescriptor && (
                            <p class="gd-age-line gd-age-desc" data-tip={topDescriptor}>
                              <span>{topDescriptor}</span>
                            </p>
                          )}
                        </div>
                        {bottomText && (
                          <>
                            <span class="gd-age-divider" aria-hidden="true"></span>
                            <p class="gd-age-line gd-age-desc" data-tip={bottomText}>
                              <span>{bottomText}</span>
                            </p>
                          </>
                        )}
                      </div>
                    </div>
                  </div>
                );
              })()}
            </div>
          )}

          {/* Languages */}
          {languageNames.length > 0 && (
            <div class="gd-side-block">
              <h3 class="gd-side-h">Languages</h3>
              <p class="gd-lang">{languageNames.join(', ')}</p>
            </div>
          )}

          {/* Useful links */}
          {otherLinks.length > 0 && (
            <div class="gd-side-block">
              <h3 class="gd-side-h">Useful Links</h3>
              <ul class="gd-link-list">
                {otherLinks.slice(0, 6).map((l) => (
                  <li><a href={l.url} target="_blank" rel="noopener">{l.label}</a></li>
                ))}
              </ul>
            </div>
          )}

          {!user && (
            <div class="gd-side-block gd-side-cta">
              <p><a href="/login">Log in</a> to track this game.</p>
            </div>
          )}
        </aside>
      </div>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="foot-brand">
          <div class="brand"><span class="logo" aria-hidden="true">▤</span> Yourshelf</div>
          <p>The first hub end-to-end analytics service for the site, designed to work with enterprises of various levels and business segments.</p>
          <p class="muted">© 2025 — Yourshelf</p>
        </div>
        <div class="foot-col">
          <h5>Game discovery</h5>
          <a href="/">Discover</a>
          <a href="/browse">Browse</a>
          <a href="/search">Search</a>
          <a href="/my-games">My Games</a>
        </div>
        <div class="foot-col">
          <h5>Info</h5>
          <a href="#">About us</a>
          <a href="#">Terms & Conditions</a>
          <a href="#">Privacy Policy</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  :root {
    --bg: #0a0c10;
    --bg-2: #0e1014;
    --surface: #14171d;
    --surface-2: #181c24;
    --border: #1f242b;
    --text: #e6e8eb;
    --muted: #8a93a0;
    --accent: #6366f1;
    --accent-2: #a78bfa;
  }
  html, body { background: var(--bg); color: var(--text); margin: 0; }
  body {
    font-family: 'Manrope', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  *, *::before, *::after { box-sizing: border-box; }
</style>

