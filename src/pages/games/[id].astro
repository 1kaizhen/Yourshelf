  .gd-hero-ratings-sub {
    display: flex;
    border-top: 0.81px solid rgba(255,255,255,0.06);
    height: 48px;
    width: 100%;
  }
  .gd-hero-ratings-sub > div {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
