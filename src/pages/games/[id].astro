<script>
  // Tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-tab-target]');
  const panels = document.querySelectorAll<HTMLElement>('[data-tab-panel]');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tabTarget;
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        p.dataset.active = p.dataset.tabPanel === target ? 'true' : 'false';
      });
    });
  });

  // Screenshot carousel
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((root) => {
    const main = root.querySelector<HTMLImageElement>('[data-carousel-main]');
    const strip = root.querySelector<HTMLElement>('[data-carousel-strip]');
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-carousel-thumb]'));
    if (!main || !strip || thumbs.length === 0) return;

    const PAGE_SIZE = 4;
    let idx = 0;
    let pageStart = 0;
    const renderPage = () => {
      const maxStart = Math.max(0, thumbs.length - PAGE_SIZE);
      pageStart = Math.max(0, Math.min(pageStart, maxStart));
      thumbs.forEach((t, j) => {
        const visible = j >= pageStart && j < pageStart + PAGE_SIZE;
        t.classList.toggle('is-hidden', !visible);
      });
    };
    const go = (next: number) => {
      idx = (next + thumbs.length) % thumbs.length;
      const full = thumbs[idx].dataset.full;
      const img = thumbs[idx].querySelector('img');
      if (full) main.src = full;
      else if (img) main.src = img.src;
      thumbs.forEach((t, j) => t.classList.toggle('is-active', j === idx));
      if (idx < pageStart) pageStart = idx;
      else if (idx >= pageStart + PAGE_SIZE) pageStart = idx - PAGE_SIZE + 1;
      renderPage();
    };
    renderPage();

    root.querySelectorAll<HTMLButtonElement>('[data-carousel-prev]').forEach((b) =>
      b.addEventListener('click', () => go(idx - 1))
    );
    root.querySelectorAll<HTMLButtonElement>('[data-carousel-next]').forEach((b) =>
      b.addEventListener('click', () => go(idx + 1))
    );
    thumbs.forEach((t, i) => t.addEventListener('click', () => go(i)));
  });
</script>
