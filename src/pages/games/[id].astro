    color: white;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 14px;
    width: 100%;
  }
  .gd-hero-ratings-sub-label {
    color: rgba(255,255,255,0.51);
    font-family: 'Urbanist', sans-serif;
    font-weight: 600;
    font-size: 10px;
    width: 100%;
    margin-top: 2px;
  }

  /* HLTB card */
  .gd-hero-hltb {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  .gd-hero-hltb-main {
    flex: 1 1 0;
    min-height: 0;
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    width: 100%;
  }
  .gd-hero-hltb-big {
    color: white;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 16px;
    line-height: normal;
    width: 100%;
  }
  .gd-hero-hltb-label {
    color: rgba(255,255,255,0.45);
    font-family: 'Urbanist', sans-serif;
    font-weight: 700;
    font-size: 12px;
    line-height: normal;
    width: 100%;
    margin-top: 2px;
  }
  .gd-hero-hltb-sub {
    display: flex;
    flex: 1 1 0;
    min-height: 0;
    border-top: 0.81px solid rgba(255,255,255,0.06);
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  .gd-hero-hltb-sub > div {
    flex: 1 1 0;
    height: 100%;
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: normal;
  }
  .gd-hero-hltb-sub > div { align-items: flex-start; text-align: left; }
  .gd-hero-hltb-sub-val {
    color: white;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 14px;
    line-height: normal;
  }
  .gd-hero-hltb-sub-label {
    color: rgba(255,255,255,0.45);
    font-family: 'Urbanist', sans-serif;
    font-weight: 600;
    font-size: 10px;
    line-height: normal;
    margin-top: 2px;
    white-space: nowrap;
  }

  /* Socials card */
  .gd-hero-socials {
    padding: 0;
  }
  .gd-hero-socials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    height: 100%;
    width: 100%;
  }
  .gd-hero-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: white;
    transition: background 0.15s;
  }
  .gd-hero-social:hover { background: rgba(255,255,255,0.05); }
  .gd-hero-social-ico {
    display: inline-flex;
    color: white;
  }
  .gd-hero-social-ico svg {
    width: 20px;
    height: 20px;
  }
  .gd-hero-social-more {
    color: white;
    font-family: 'Urbanist', sans-serif;
    font-weight: 700;
    font-size: 12px;
  }
  .gd-hero-socials-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: rgba(255,255,255,0.45);
    font-size: 12px;
  }

  /* Action buttons */
  .gd-hero-actions {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .gd-trailer-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #851dd5;
    color: white;
    text-decoration: none;
    border: 0.9px solid rgba(255,255,255,0.18);
    padding: 9px 14px;
    border-radius: 7px;
    font-family: 'Urbanist', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.4;
    cursor: pointer;
    transition: background 0.15s;
  }
  .gd-trailer-btn:hover { background: #9528ee; }
  .gd-trailer-btn--disabled { background: #2a2f38; opacity: 0.7; cursor: default; }
  .gd-bookmark-form { margin: 0; }
  .gd-bookmark-btn {
    width: 37.3px; height: 37.3px;
    background: #851dd5;
    color: white;
    border: 0.9px solid rgba(255,255,255,0.18);
    border-radius: 7px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 0.15s;
  }
  .gd-bookmark-btn:hover { background: #9528ee; }
  .gd-bookmark-btn.is-active { background: #9528ee; }

  /* ---------- MAIN ---------- */
  .gd-main {
    max-width: 1240px; margin: 0 auto; width: 100%;
    padding: 56px 2.5rem 4rem;
  }

  .gd-track-strip {
    display: flex; flex-wrap: wrap; gap: 16px; justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
  }
  .gd-track-row { display: flex; flex-wrap: wrap; gap: 8px; margin: 0; }
  .gd-pill {
    background: transparent; border: 1px solid #2a3038; color: #c5cbd2;
    padding: 0.45rem 0.95rem; border-radius: 999px; cursor: pointer;
    font: inherit; font-size: 0.85rem;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .gd-pill:hover { border-color: #851dd5; color: white; }
  .gd-pill.is-active { background: #851dd5; border-color: #851dd5; color: white; }
  .gd-track-meta { display: flex; gap: 12px; align-items: center; margin: 0; }
  .gd-rating-input { display: flex; align-items: center; gap: 6px; color: var(--muted); font-size: 0.85rem; }
  .gd-rating-input input {
    width: 56px; background: var(--bg); color: white;
    border: 1px solid var(--border); border-radius: 8px;
    padding: 6px 10px; font: inherit;
  }
  .gd-save-btn {
    background: #851dd5; color: white; border: none;
    padding: 8px 16px; border-radius: 8px; font-weight: 600; font-size: 0.85rem;
    cursor: pointer;
  }
  .gd-save-btn:hover { background: #9528ee; }

  .gd-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 286px;
    gap: 32px;
  }
  .gd-col-main { min-width: 0; display: flex; flex-direction: column; gap: 56px; }
  .gd-col-side { display: flex; flex-direction: column; gap: 32px; padding-top: 44px; }

  .gd-block { display: flex; flex-direction: column; gap: 16px; }
  .gd-h2 {
    margin: 0; color: white;
    font-size: 20px; font-weight: 700;
    letter-spacing: -0.6px; line-height: 1.4;
  }
  .gd-empty { color: var(--muted); margin: 0; font-size: 0.9rem; }

  /* Screenshots — Figma 192:51 */
  .gd-carousel { display: flex; flex-direction: column; gap: 16px; }
  .gd-carousel-main {
    position: relative; width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 14px; overflow: hidden;
    background: #11151a;
  }
  .gd-carousel-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  .gd-carousel-edge {
    position: absolute; top: 0; bottom: 0;
    width: 72px;
    border: none; padding: 0;
    display: flex; align-items: center;
    color: #fff; cursor: pointer;
    opacity: 0; transition: opacity 180ms ease;
  }
  .gd-carousel-main:hover .gd-carousel-edge,
  .gd-carousel-edge:focus-visible { opacity: 1; }
  .gd-carousel-edge--left {
    left: 0; justify-content: flex-start; padding-left: 20px;
    background: linear-gradient(90deg, rgba(17,16,20,1) 14%, rgba(17,16,20,0.5) 72%, rgba(17,16,20,0) 98%);
  }
  .gd-carousel-edge--right {
    right: 0; justify-content: flex-end; padding-right: 20px;
    background: linear-gradient(270deg, rgba(17,16,20,1) 2%, rgba(17,16,20,0.5) 60%, rgba(17,16,20,0) 85%);
  }
  .gd-carousel-edge svg { display: block; }

  .gd-carousel-thumbs {
    display: flex; gap: 11px; align-items: center;
    width: 100%;
  }
  .gd-carousel-navbtn {
    flex: 0 0 auto;
    width: 36px; height: 108px;
    background: #090a0c; border: none;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer;
    transition: background 150ms ease;
  }
  .gd-carousel-navbtn:hover { background: #15171b; }
  .gd-carousel-navbtn svg { display: block; }

  .gd-carousel-strip {
    flex: 1 1 0; min-width: 0;
    display: flex; gap: 8.416px;
    overflow: visible;
  }
  .gd-carousel-thumb {
    flex: 0 0 calc((100% - 3 * 8.416px) / 4);
    height: 108px;
    padding: 0; border: 1px solid transparent;
    background: transparent;
    border-radius: 8.416px; overflow: hidden;
    cursor: pointer;
    position: relative;
    box-sizing: border-box;
    transition: border-color 150ms ease, transform 150ms ease;
  }
  .gd-carousel-thumb.is-hidden { display: none; }
  .gd-carousel-thumb img {
    width: 100%; height: 100%; object-fit: cover;
    display: block; border-radius: 7.4px;
  }
  .gd-carousel-thumb.is-active {
    border-color: rgba(255, 255, 255, 0.4);
  }
  .gd-carousel-thumb:hover:not(.is-active) {
    border-color: rgba(255, 255, 255, 0.18);
  }

  /* About */
  .gd-prose {
    color: rgba(230,232,235,0.78);
    font-size: 0.95rem;
    line-height: 1.65;
    white-space: pre-line;
    margin: 0;
  }
  .gd-storyline { margin-top: 28px; }
  .gd-storyline-h {
    margin: 0 0 10px;
    color: white;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Specs */
  /* Specs table — Figma 193:1028 */
  .gd-specs {
    background: transparent;
    border: none;
    border-radius: 0;
    overflow: hidden;
    font-family: 'Urbanist', system-ui, sans-serif;
  }
  .gd-specs-head, .gd-specs-row {
    display: grid; grid-template-columns: 174px 1fr 1fr;
    align-items: stretch;
  }
  .gd-specs-head { min-height: 62px; }
  .gd-specs-row { min-height: 62px; }
  .gd-specs-row:nth-of-type(2) { min-height: 56px; }

  .gd-specs-cell {
    padding: 16px 20px;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.42px;
    line-height: 1.6;
    display: flex; align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .gd-specs-row:last-child .gd-specs-cell { border-bottom: 1px solid rgba(255, 255, 255, 0.12); }

  /* Left "Components" column — continuous fill + right divider, no row borders */
  .gd-specs-cell--label {
    background: rgba(255, 255, 255, 0.02);
    border-bottom: none;
    border-right: 1px solid rgba(255, 255, 255, 0.12);
    padding: 16px;
    gap: 10px;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  .gd-specs-ico {
    flex: 0 0 auto;
    display: inline-flex; align-items: center; justify-content: center;
    color: rgba(255, 255, 255, 0.7);
  }
  .gd-specs-ico img { width: 100%; height: 100%; display: block; }
  /* Header row uses 30px component icon */
  .gd-specs-head .gd-specs-ico { width: 30px; height: 30px; }
  .gd-specs-cell--head {
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Tabs — Figma 197:2930 */
  .gd-tabs {
    display: flex; align-items: center;
    width: 100%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
    border-radius: 0;
    padding: 0;
    gap: 0;
  }
  .gd-tab {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    padding: 10px 16px;
    color: rgba(255, 255, 255, 0.6);
    font-family: 'Urbanist', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.48px;
    line-height: 1.4;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .gd-tab:hover { color: rgba(255, 255, 255, 0.85); }
  .gd-tab.is-active {
    color: #fff;
    font-weight: 700;
    border-bottom-color: #fff;
    background: transparent;
  }
  .gd-tab-count {
    color: inherit; opacity: 0.7;
    font-size: 13px; font-weight: 500;
    background: transparent;
    border-radius: 0;
    padding: 0;
  }
  .gd-tab-panel { display: none; margin-top: 16px; }
  .gd-tab-panel[data-active="true"] { display: block; }

  /* Related grid */
  .gd-related-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  }
  .gd-related-card {
    display: flex; flex-direction: column; gap: 10px;
    text-decoration: none; color: inherit;
    transition: transform 0.15s;
  }
  .gd-related-card:hover { transform: translateY(-2px); }
  .gd-related-cover {
    aspect-ratio: 179 / 221;
    border-radius: 10px; overflow: hidden;
    background: #11151a;
  }
  .gd-related-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gd-cover-fallback { width: 100%; height: 100%; background: linear-gradient(135deg, #1a1f26, #11151a); }
  .gd-related-meta { display: flex; flex-direction: column; gap: 2px; }
  .gd-related-rating { color: rgba(255,255,255,0.6); font-size: 0.72rem; font-weight: 500; }
  .gd-related-name { color: white; font-size: 0.95rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1.3; }
  .gd-related-sub { color: var(--muted); font-size: 0.78rem; }

  /* ---------- SIDEBAR ---------- */
  .gd-side-banner {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 16px;
    border-radius: 10px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .gd-side-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }
  .gd-side-title {
    width: 100%;
    color: white;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 18px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-align: left;
  }
  .gd-side-logo {
    max-width: 100%;
    max-height: 80px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 4px 16px rgba(0,0,0,0.5));
  }
  .gd-side-logo-fallback {
    color: white;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 18px;
    text-align: center;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .gd-side-block { display: flex; flex-direction: column; gap: 12px; }
  .gd-side-h {
    margin: 0; color: white;
    font-size: 0.95rem; font-weight: 700;
    letter-spacing: -0.02em;
  }

  /* Store grid */
  .gd-store-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
  }
  .gd-store-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--surface); color: white; text-decoration: none;
    border: 1px solid var(--border);
    padding: 10px 14px; border-radius: 8px;
    font-size: 0.82rem; font-weight: 600;
    transition: border-color 0.15s, background 0.15s;
  }
  .gd-store-btn:hover { border-color: #851dd5; background: rgba(133,29,213,0.10); }
  .gd-store-ico,
  .gd-store-ico svg { background: transparent; border: none; }
  .gd-store-ico { display: inline-flex; }

  /* Tag cloud */
  .gd-tag-cloud { display: flex; flex-wrap: wrap; gap: 6px; }
  .gd-tag {
    background: var(--surface); color: white;
    padding: 4px 12px; border-radius: 999px;
    border: 1px solid var(--border);
    font-size: 0.78rem; font-weight: 500;
  }

  /* Info table */
  .gd-info { margin: 0; display: flex; flex-direction: column; }
  .gd-info-row {
    display: flex; justify-content: space-between; gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .gd-info-row:last-child { border-bottom: none; }
  .gd-info dt { color: var(--muted); font-size: 0.82rem; }
  .gd-info dd { color: white; font-size: 0.85rem; margin: 0; text-align: right; font-weight: 500; max-width: 60%; }

  /* Age rating — Figma 188:2 */
  .gd-age {
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
    overflow: visible;
    position: relative;
  }
  .gd-age-row {
    display: flex; gap: 12px; align-items: center;
  }
  .gd-age-badge {
    width: 65px; height: 79px; flex-shrink: 0;
    background: linear-gradient(180deg, #851dd5, #5b14a0);
    border-radius: 6px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    color: white; gap: 2px;
    align-self: center;
  }
  .gd-age-img {
    width: 65px; height: auto; max-height: 84px;
    flex-shrink: 0; flex-grow: 0;
    object-fit: contain; display: block;
    align-self: center;
  }
  .gd-age-num { font-size: 1.4rem; font-weight: 800; line-height: 1; }
  .gd-age-board { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.06em; opacity: 0.85; }
  .gd-age-body {
    font-family: 'Urbanist', system-ui, sans-serif;
    flex: 1 1 auto; min-width: 0;
    display: flex; flex-direction: column; gap: 2px;
    justify-content: center;
  }
  .gd-age-head { display: flex; flex-direction: column; gap: 0; min-width: 0; }
  .gd-age-line {
    margin: 0; min-width: 0; max-width: 100%;
    padding: 1px 0; cursor: default;
    position: relative;
    overflow: visible;
  }
  .gd-age-line > span {
    display: block; max-width: 100%;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .gd-age-code {
    color: #fff;
    font-weight: 700; font-size: 18px;
    letter-spacing: -0.54px; line-height: 1.4;
  }
  .gd-age-desc {
    color: rgba(255, 255, 255, 0.58);
    font-weight: 500; font-size: 14px;
    letter-spacing: -0.42px; line-height: 1.4;
  }
  .gd-age-divider {
    display: block; height: 1px; width: 100%;
    background: rgba(255, 255, 255, 0.12);
  }

  /* Tooltip on truncated age-rating lines */
  .gd-age-body [data-tip] { position: relative; }
  .gd-age-body [data-tip]::after {
    content: attr(data-tip);
    position: absolute;
    left: 0; bottom: calc(100% + 6px);
    z-index: 30;
    padding: 6px 10px;
    background: #111418;
    color: #fff;
    font-family: 'Urbanist', system-ui, sans-serif;
    font-weight: 500; font-size: 12px; line-height: 1.4;
    letter-spacing: -0.2px;
    white-space: normal;
    max-width: 240px; width: max-content;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 6px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
    opacity: 0; pointer-events: none;
    transform: translateY(2px);
    transition: opacity 120ms ease, transform 120ms ease;
  }
  .gd-age-body [data-tip]:hover::after,
  .gd-age-body [data-tip]:focus-visible::after {
    opacity: 1; transform: translateY(0);
  }

  .gd-lang { margin: 0; color: #d5d9de; font-size: 0.85rem; line-height: 1.6; }

  .gd-link-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  .gd-link-list a {
    color: #c5cbd2; text-decoration: none; font-size: 0.85rem;
    padding: 0.35rem 0; border-radius: 0;
    display: block; background: transparent; border: none;
    transition: color 0.15s;
  }
  .gd-link-list a:hover { color: #b06be4; }

  .gd-side-cta { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 14px; }
  .gd-side-cta p { margin: 0; color: var(--muted); font-size: 0.85rem; }
  .gd-side-cta a { color: var(--accent-2); }

  /* ---------- FOOTER (matches homepage) ---------- */
  .footer { background: var(--bg-2); border-top: 1px solid var(--border); padding: 2.5rem 2.5rem 2rem; margin-top: 64px; }
  .footer-inner {
    max-width: 1240px; margin: 0 auto;
    display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem;
  }
  .foot-brand .brand { display: inline-flex; align-items: center; gap: 0.4rem; font-weight: 700; margin-bottom: 0.75rem; color: white; }
  .foot-brand .logo { color: var(--accent-2); }
  .foot-brand p { color: var(--muted); font-size: 0.82rem; line-height: 1.6; max-width: 38ch; margin: 0 0 0.6rem; }
  .foot-brand .muted { font-size: 0.78rem; }
  .foot-col h5 { margin: 0 0 0.9rem; font-size: 0.78rem; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; }
