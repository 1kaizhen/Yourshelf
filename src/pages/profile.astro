---
import Layout from '../layouts/Layout.astro';

const { supabase, user } = Astro.locals;
const currentUser = user!;

const RESERVED = new Set([
  'login', 'signup', 'logout', 'verify', 'profile', 'my-games',
  'admin', 'api', 'auth', 'settings', 'about', 'help', 'support',
]);
const USERNAME_RE = /^[a-zA-Z0-9_-]{2,30}$/;

let updateError: string | null = null;
let updated = false;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const newUsername = String(form.get('username') ?? '').trim();

  if (!USERNAME_RE.test(newUsername)) {
    updateError = 'Username must be 2–30 chars: letters, numbers, _ or -.';
  } else if (RESERVED.has(newUsername.toLowerCase())) {
    updateError = 'That username is reserved.';
  } else {
    const { error } = await supabase
      .from('profiles')
      .update({ username: newUsername })
      .eq('id', currentUser.id);

    if (error) {
      updateError = error.code === '23505' ? 'That username is already taken.' : error.message;
    } else {
      updated = true;
    }
  }
}

const { data: profile, error: profileError } = await supabase
  .from('profiles')
  .select('username, avatar_url, created_at')
  .eq('id', currentUser.id)
  .single();

const initial = (profile?.username ?? currentUser.email ?? '?').charAt(0).toUpperCase();
const memberSince = profile?.created_at
  ? new Date(profile.created_at).toLocaleDateString(undefined, { year: 'numeric', month: 'long' })
  : null;
---

<Layout>
  <div class="page">
    <nav class="topbar">
      <a href="/" class="brand">Yourshelf</a>
      <a href="/logout" class="logout">Log out</a>
    </nav>

    <main class="container">
      <header class="hero">
        {profile?.avatar_url ? (
          <img src={profile.avatar_url} alt="avatar" class="avatar" />
        ) : (
          <div class="avatar avatar-fallback">{initial}</div>
        )}
        <div class="hero-text">
          <h1>{profile?.username ?? 'Set your username'}</h1>
          <p class="muted">{currentUser.email}</p>
          {memberSince && <p class="muted small">Member since {memberSince}</p>}
          {profile?.username && (
            <a href={`/${profile.username}`} class="public-link">View public profile →</a>
          )}
        </div>
      </header>

      {profileError && <p class="alert error">{profileError.message}</p>}

      <section class="card">
        <h2>Account details</h2>
        <dl class="details">
          <dt>Email</dt>
          <dd>{currentUser.email}</dd>
          <dt>Username</dt>
          <dd>{profile?.username ?? <span class="muted">Not set</span>}</dd>
          <dt>User ID</dt>
          <dd class="mono">{currentUser.id}</dd>
        </dl>
      </section>

      <section class="card">
        <h2>Edit profile</h2>
        <form method="POST" class="form">
          <label class="field">
            <span>Username</span>
            <input name="username" value={profile?.username ?? ''} required minlength="2" />
          </label>
          {updateError && <p class="alert error">{updateError}</p>}
          {updated && <p class="alert success">Username updated.</p>}
          <button type="submit" class="btn-primary">Save changes</button>
        </form>
      </section>
    </main>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0b0d10;
    color: #e6e8eb;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .page { min-height: 100vh; }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #1f242b;
    background: #0e1116;
  }
  .brand {
    font-weight: 700;
    font-size: 1.05rem;
    color: #e6e8eb;
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .logout {
    color: #9aa3ad;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .logout:hover { color: #e6e8eb; }

  .container {
    max-width: 44rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  .hero {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #1f242b;
  }
  .avatar-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    font-size: 2rem;
    font-weight: 600;
  }
  .hero-text h1 {
    margin: 0 0 0.25rem;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
  }
  .muted { color: #9aa3ad; margin: 0.15rem 0; }
  .public-link {
    display: inline-block; margin-top: 0.4rem; color: #818cf8;
    text-decoration: none; font-size: 0.9rem;
  }
  .public-link:hover { color: #a5b4fc; }
  .small { font-size: 0.85rem; }

  .card {
    background: #11151a;
    border: 1px solid #1f242b;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .card h2 {
    margin: 0 0 1rem;
    font-size: 1rem;
    font-weight: 600;
    color: #c5cbd2;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .details {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.6rem 1rem;
    margin: 0;
  }
  .details dt { color: #9aa3ad; font-size: 0.9rem; }
  .details dd { margin: 0; word-break: break-all; }
  .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem; color: #c5cbd2; }

  .form { display: flex; flex-direction: column; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field span { font-size: 0.9rem; color: #c5cbd2; }
  .field input {
    background: #0b0d10;
    border: 1px solid #2a3038;
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    color: #e6e8eb;
    font-size: 0.95rem;
    transition: border-color 0.15s;
  }
  .field input:focus {
    outline: none;
    border-color: #6366f1;
  }

  .btn-primary {
    align-self: flex-start;
    background: #6366f1;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.6rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-primary:hover { background: #5457e0; }

  .alert {
    border-radius: 8px;
    padding: 0.6rem 0.85rem;
    font-size: 0.9rem;
    margin: 0;
  }
  .alert.error { background: #2a1416; color: #ff8a93; border: 1px solid #4a1f24; }
  .alert.success { background: #0f2a1a; color: #6fdb9b; border: 1px solid #1f4a30; }

  @media (max-width: 540px) {
    .hero { flex-direction: column; text-align: center; }
    .details { grid-template-columns: 1fr; gap: 0.25rem 0; }
    .details dt { margin-top: 0.5rem; }
  }
</style>
