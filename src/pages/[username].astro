---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const { username } = Astro.params;
const { supabase, user } = Astro.locals;

const { data: profile } = await supabase
  .from('profiles')
  .select('id, username, avatar_url, created_at')
  .ilike('username', username ?? '')
  .maybeSingle();

if (!profile) {
  return new Response('Not found', { status: 404 });
}

const isOwner = user?.id === profile.id;
const initial = (profile.username ?? '?').charAt(0).toUpperCase();
const memberSince = new Date(profile.created_at).toLocaleDateString(undefined, {
  year: 'numeric',
  month: 'long',
});
---

<Layout>
  <div class="page">
    <Nav />

    <main class="container">
      <header class="hero">
        {profile.avatar_url ? (
          <img src={profile.avatar_url} alt={`${profile.username} avatar`} class="avatar" />
        ) : (
          <div class="avatar avatar-fallback">{initial}</div>
        )}
        <div class="hero-text">
          <h1>@{profile.username}</h1>
          <p class="muted small">Member since {memberSince}</p>
          {isOwner && <a href="/profile" class="edit-link">Edit your profile →</a>}
        </div>
      </header>

      <section class="card">
        <h2>Game shelf</h2>
        <p class="muted">No games added yet.</p>
      </section>
    </main>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0b0d10;
    color: #e6e8eb;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .page { min-height: 100vh; }

  .container { max-width: 44rem; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

  .hero { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 2rem; }
  .avatar { width: 88px; height: 88px; border-radius: 50%; object-fit: cover; border: 2px solid #1f242b; }
  .avatar-fallback {
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white; font-size: 2rem; font-weight: 600;
  }
  .hero-text h1 { margin: 0 0 0.25rem; font-size: 1.5rem; letter-spacing: -0.02em; }
  .muted { color: #9aa3ad; margin: 0.15rem 0; }
  .small { font-size: 0.85rem; }
  .edit-link {
    display: inline-block; margin-top: 0.5rem; color: #818cf8;
    text-decoration: none; font-size: 0.9rem;
  }
  .edit-link:hover { color: #a5b4fc; }

  .card {
    background: #11151a; border: 1px solid #1f242b; border-radius: 12px;
    padding: 1.5rem; margin-bottom: 1.25rem;
  }
  .card h2 {
    margin: 0 0 1rem; font-size: 1rem; font-weight: 600; color: #c5cbd2;
    text-transform: uppercase; letter-spacing: 0.06em;
  }

  @media (max-width: 540px) {
    .hero { flex-direction: column; text-align: center; }
  }
</style>
