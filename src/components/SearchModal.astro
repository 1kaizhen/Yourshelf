---
import { fetchDiscover, fetchCardsByIds } from '../lib/api';

const recommendedLite = await fetchDiscover({ sort: 'rating', limit: 12 });
const trendingLite = await fetchDiscover({ sort: 'rating', limit: 10 });
const ids = Array.from(new Set([...recommendedLite, ...trendingLite].map((g) => g.igdb_id)));
const enriched = await fetchCardsByIds(ids);
const enrichedMap = new Map(enriched.map((c) => [c.igdb_id, c]));
const recommended = recommendedLite.map((g) => enrichedMap.get(g.igdb_id) ?? g);
const trending = trendingLite.map((g) => enrichedMap.get(g.igdb_id) ?? g);

const recommendedJson = JSON.stringify(recommended);
const trendingJson = JSON.stringify(trending);

const categories = [
  { key: 'rating', label: 'Trending Game' },
  { key: 'release_date', label: 'Newest Games' },
  { key: 'story', label: 'Story Driven Games' },
  { key: 'adventure', label: 'Adventure Games' },
  { key: 'shooter', label: 'Shooter Games' },
];
---

<div class="sm-overlay" id="searchModal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search games">
  <div class="sm-backdrop" data-close></div>
  <div class="sm-panel">
    <div class="sm-head">
      <div class="sm-input-wrap">
        <svg class="sm-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        <input
          type="search"
          id="searchModalInput"
          placeholder="Search your Games & DLC..."
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <div class="sm-kbd">Ctrl + K</div>
    </div>

    <div class="sm-body">
      <aside class="sm-side">
        {categories.map((c, i) => (
          <button class={`sm-side-item${i === 0 ? ' active' : ''}`} data-cat={c.key} type="button">
            <svg class="sm-side-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 17l6-6 4 4 7-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 7h6v6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{c.label}</span>
          </button>
        ))}
      </aside>

      <div class="sm-main">
        <section class="sm-section" id="searchThumbRow">
          <div class="sm-section-head">
            <h3>Recommended Games</h3>
          </div>
          <div class="sm-thumb-wrap">
            <button class="sm-arrow" type="button" data-thumb-prev aria-label="Previous">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="sm-thumb-viewport">
              <div class="sm-thumb-strip" id="searchThumbStrip"></div>
            </div>
            <button class="sm-arrow" type="button" data-thumb-next aria-label="Next">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </section>

        <section class="sm-section sm-trend">
          <div class="sm-section-head">
            <h3 id="searchTrendTitle">Trending Games</h3>
          </div>
          <div class="sm-card-grid" id="searchTrendGrid"></div>
        </section>

        <section class="sm-section" id="searchResultsRow" hidden>
          <div class="sm-section-head">
            <h3 id="searchResultsTitle">Results</h3>
          </div>
          <div class="sm-card-grid" id="searchResultsGrid"></div>
          <p class="sm-hint" id="searchHint"></p>
        </section>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ recommendedJson, trendingJson, apiBase: import.meta.env.PUBLIC_API_URL }}>
  (function () {
    const modal = document.getElementById('searchModal');
    if (!modal) return;
    const input = document.getElementById('searchModalInput');
    const thumbStrip = document.getElementById('searchThumbStrip');
    const trendGrid = document.getElementById('searchTrendGrid');
    const trendTitle = document.getElementById('searchTrendTitle');
    const trendSection = modal.querySelector('.sm-trend');
    const thumbSection = document.getElementById('searchThumbRow');
    const resultsSection = document.getElementById('searchResultsRow');
    const resultsGrid = document.getElementById('searchResultsGrid');
    const resultsTitle = document.getElementById('searchResultsTitle');
    const hint = document.getElementById('searchHint');
    const sideButtons = modal.querySelectorAll('.sm-side-item');
    const thumbPrev = modal.querySelector('[data-thumb-prev]');
    const thumbNext = modal.querySelector('[data-thumb-next]');

    const recommended = JSON.parse(recommendedJson);
    const trending = JSON.parse(trendingJson);

    function esc(s) { return String(s).replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c]); }

    function thumbHTML(g) {
      const img = g.cover_url
        ? `<img src="${g.cover_url}" alt="" loading="lazy" />`
        : `<div class="sm-ph"></div>`;
      return `<a class="sm-thumb" href="/games/${g.igdb_id}" title="${esc(g.name)}">${img}</a>`;
    }

    function ratingLabel(g) {
      const r = g.rating;
      if (r == null) return '';
      // Backend rating is 0–100 (IGDB scale); show as X.X/10
      const val = r > 10 ? r / 10 : r;
      return `${val.toFixed(1)}/10 Rating`;
    }

    function cardHTML(g) {
      const img = g.cover_url
        ? `<img src="${g.cover_url}" alt="" loading="lazy" />`
        : `<div class="sm-ph"></div>`;
      const label = ratingLabel(g);
      const ratingDiv = label ? `<div class="sm-card-rating">${esc(label)}</div>` : '';
      return `<a class="sm-card" href="/games/${g.igdb_id}">
        <div class="sm-card-cover">${img}</div>
        <div class="sm-card-meta">
          ${ratingDiv}
          <div class="sm-card-name">${esc(g.name)}</div>
        </div>
      </a>`;
    }

    thumbStrip.innerHTML = recommended.map(thumbHTML).join('');
    trendGrid.innerHTML = trending.slice(0, 10).map(cardHTML).join('');

    const thumbViewport = thumbStrip.parentElement;
    function scrollThumbs(dir) {
      if (!thumbViewport) return;
      const first = thumbStrip.querySelector('.sm-thumb');
      const step = first ? (first.getBoundingClientRect().width + 10) : 80;
      const visible = Math.max(1, Math.floor(thumbViewport.clientWidth / step));
      thumbViewport.scrollBy({ left: dir * step * visible, behavior: 'smooth' });
    }
    thumbPrev?.addEventListener('click', () => scrollThumbs(-1));
    thumbNext?.addEventListener('click', () => scrollThumbs(1));

    // Auto-hide scrollbar — show only while actively scrolling
    function attachAutoHideScrollbar(el) {
      if (!el) return;
      let t = null;
      el.addEventListener('scroll', () => {
        el.classList.add('is-scrolling');
        if (t) clearTimeout(t);
        t = setTimeout(() => el.classList.remove('is-scrolling'), 700);
      }, { passive: true });
    }
    attachAutoHideScrollbar(modal.querySelector('.sm-main'));
    attachAutoHideScrollbar(modal.querySelector('.sm-side'));

    function open() {
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input.focus(), 30);
    }
    function close() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      input.value = '';
      showDefault();
    }
    function showDefault() {
      resultsSection.hidden = true;
      thumbSection.hidden = false;
      trendSection.hidden = false;
      hint.textContent = '';
      modal.classList.remove('is-searching');
    }
    function showResults() {
      resultsSection.hidden = false;
      thumbSection.hidden = true;
      trendSection.hidden = true;
      modal.classList.add('is-searching');
    }

    modal.addEventListener('click', (e) => {
      if (e.target.matches('[data-close]')) close();
    });

    document.addEventListener('keydown', (e) => {
      const isMac = navigator.platform.toLowerCase().includes('mac');
      if ((isMac ? e.metaKey : e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        open();
      }
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
        close();
      }
    });

    document.querySelectorAll('[data-open-search]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    let ctrl = null;
    let timer = null;
    input.addEventListener('input', () => {
      const q = input.value.trim();
      if (timer) clearTimeout(timer);
      if (ctrl) ctrl.abort();
      if (!q) { showDefault(); return; }
      hint.textContent = 'Searching…';
      showResults();
      resultsTitle.textContent = `Results for "${q}"`;
      timer = setTimeout(async () => {
        ctrl = new AbortController();
        try {
          const res = await fetch(`${apiBase}/api/search?q=${encodeURIComponent(q)}`, { signal: ctrl.signal });
          if (!res.ok) throw new Error('search failed');
          const data = await res.json();
          const items = data.results || [];
          if (items.length === 0) {
            resultsGrid.innerHTML = '';
            hint.textContent = 'No matches.';
          } else {
            resultsGrid.innerHTML = items.slice(0, 12).map(cardHTML).join('');
            hint.textContent = items.length > 12 ? `Showing 12 of ${items.length}. Press Enter to see all.` : '';
          }
        } catch (err) {
          if (err.name !== 'AbortError') hint.textContent = 'Search failed';
        }
      }, 250);
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const q = input.value.trim();
        if (q) window.location.href = `/search?q=${encodeURIComponent(q)}`;
      }
    });

    sideButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        sideButtons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.cat;
        const label = btn.textContent.trim();
        trendTitle.textContent = label.replace(/Game$/, 'Games');
        showDefault();
        const params = new URLSearchParams();
        if (cat === 'rating' || cat === 'release_date') params.set('sort', cat);
        else if (cat === 'story' || cat === 'adventure' || cat === 'shooter') params.set('genre', cat);
        params.set('limit', '10');
        fetch(`${apiBase}/api/discover?${params.toString()}`)
          .then((r) => r.ok ? r.json() : { results: [] })
          .then((d) => {
            trendGrid.innerHTML = (d.results || []).slice(0, 10).map(cardHTML).join('');
          })
          .catch(() => {});
      });
    });
  })();
</script>

<style is:global>
  /* Overlay & backdrop */
  .sm-overlay {
    position: fixed; inset: 0; z-index: 1000;
    display: none;
    align-items: center; justify-content: center;
    padding: 2rem;
    font-family: 'Urbanist', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  .sm-overlay[aria-hidden='false'] { display: flex; }
  .sm-backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Panel — matches Figma: bg #191919, radius 29.079px */
  .sm-panel {
    position: relative;
    width: min(68.5rem, calc(100% - 3rem));
    margin: 0 auto;
    height: min(720px, calc(100vh - 4rem));
    background: #191919;
    border-radius: 29.079px;
    overflow: hidden;
    display: flex; flex-direction: column;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
  }

  /* Head — pt 24 pb 20 px 24, border-bottom 0.08 white */
  .sm-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 24px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }
  .sm-input-wrap {
    flex: 1;
    display: flex; align-items: center; gap: 8px;
    min-width: 0;
    margin-right: 16px;
  }
  .sm-icon { color: rgba(255, 255, 255, 0.26); flex-shrink: 0; }
  #searchModalInput {
    flex: 1; min-width: 0;
    background: transparent; border: 0; outline: 0;
    color: #fff;
    font-family: inherit;
    font-weight: 500;
    font-size: 16px;
    letter-spacing: normal;
    padding-right: 8px;
  }
  #searchModalInput::placeholder {
    color: rgba(255, 255, 255, 0.32);
    font-weight: 500;
    letter-spacing: normal;
  }
  .sm-kbd {
    background: #2c2c2c;
    width: 52px;
    padding: 8px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: -0.48px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Body: 2-column */
  .sm-body {
    display: flex;
    flex: 1; min-height: 0;
  }

  /* Sidebar — 250px, border-right 0.08, padding 16px 12px, gap 4px */
  .sm-side {
    width: 250px;
    flex-shrink: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    padding: 16px 12px;
    display: flex; flex-direction: column; gap: 4px;
    overflow-y: auto;
  }
  .sm-side-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px; border-radius: 8px;
    background: transparent; border: 0;
    color: rgba(255, 255, 255, 0.32);
    font-family: inherit;
    font-weight: 500; /* Medium */
    font-size: 16px;
    letter-spacing: normal;
    text-align: left;
    cursor: pointer;
    width: 100%;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .sm-side-item:hover { color: rgba(255, 255, 255, 0.65); }
  .sm-side-item.active {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    font-weight: 700; /* Bold */
  }
  .sm-side-item .sm-side-icon { opacity: 0.6; transition: opacity 0.15s ease; }
  .sm-side-item.active .sm-side-icon { opacity: 1; }
  .sm-side-icon { flex-shrink: 0; }

  /* Main — flex column, gap 24, padding 16 */
  .sm-main {
    flex: 1; min-width: 0;
    padding: 16px;
    display: flex; flex-direction: column; gap: 24px;
    overflow-y: auto;
  }

  /* Section — gap 8, full width */
  .sm-section {
    display: flex; flex-direction: column; gap: 8px;
  }
  .sm-section-head {
    display: flex; align-items: center; justify-content: center;
    padding: 8px 0;
  }
  .sm-section-head h3 {
    margin: 0;
    flex: 1;
    color: #fff;
    font-family: inherit;
    font-weight: 700; /* Bold */
    font-size: 18px;
    letter-spacing: -0.72px;
  }

  /* Thumb row — compact arrows + poster-aspect thumbs with edge fade */
  .sm-thumb-wrap {
    display: flex; gap: 10px; align-items: stretch; justify-content: center;
    width: 100%;
  }
  .sm-arrow {
    flex: 0 0 32px; width: 32px;
    background: #242424;
    border: 0; border-radius: 6px;
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .sm-arrow:hover { background: #2e2e2e; }
  .sm-thumb-viewport {
    flex: 1 1 auto;
    min-width: 0;
    position: relative;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%);
            mask-image: linear-gradient(to right, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%);
  }
  .sm-thumb-viewport::-webkit-scrollbar { display: none; }
  .sm-thumb-strip {
    display: flex; gap: 10px;
    width: max-content;
  }
  .sm-thumb {
    flex: 0 0 128px;
    width: 128px;
    aspect-ratio: 3 / 4;
    border-radius: 6px;
    overflow: hidden;
    background: #242424;
    display: block;
    transition: transform 0.15s, outline 0.15s;
    outline: 1px solid transparent;
  }
  .sm-thumb:hover { outline-color: rgba(255, 255, 255, 0.2); }
  .sm-thumb img, .sm-thumb .sm-ph {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Card grid — 5 per row, fixed 3:4 cover ratio */
  .sm-card-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    column-gap: 14px;
    row-gap: 28px;
  }
  .sm-card {
    display: flex; flex-direction: column; gap: 10px;
    text-decoration: none; color: inherit;
    min-width: 0;
    transition: transform 0.15s;
  }
  .sm-card:hover { transform: translateY(-2px); }
  .sm-card-cover {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 10px;
    overflow: hidden;
    background: #242424;
  }
  .sm-card-cover img, .sm-card-cover .sm-ph {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .sm-card-meta {
    display: flex; flex-direction: column; gap: 1px;
  }
  .sm-card-rating {
    font-family: inherit;
    font-weight: 500; /* Medium */
    font-size: 11px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.35;
    letter-spacing: -0.22px;
  }
  .sm-card-name {
    font-family: inherit;
    font-weight: 700; /* Bold */
    font-size: 15px;
    color: #fff;
    letter-spacing: -0.45px;
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .sm-section[hidden] { display: none !important; }

  /* Hide category sidebar while searching */
  .sm-overlay.is-searching .sm-side { display: none; }

  /* Custom scrollbar — dark theme, auto-hide when idle */
  .sm-main,
  .sm-side {
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    transition: scrollbar-color 0.25s ease;
  }
  .sm-main::-webkit-scrollbar,
  .sm-side::-webkit-scrollbar { width: 8px; height: 8px; }
  .sm-main::-webkit-scrollbar-track,
  .sm-side::-webkit-scrollbar-track { background: transparent; }
  .sm-main::-webkit-scrollbar-thumb,
  .sm-side::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 8px;
    border: 2px solid transparent;
    background-clip: padding-box;
    transition: background 0.25s ease;
  }
  .sm-main.is-scrolling,
  .sm-side.is-scrolling,
  .sm-main:hover,
  .sm-side:hover { scrollbar-color: rgba(255, 255, 255, 0.18) transparent; }
  .sm-main.is-scrolling::-webkit-scrollbar-thumb,
  .sm-side.is-scrolling::-webkit-scrollbar-thumb,
  .sm-main:hover::-webkit-scrollbar-thumb,
  .sm-side:hover::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.18);
    background-clip: padding-box;
  }
  .sm-main::-webkit-scrollbar-thumb:hover,
  .sm-side::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3) !important;
    background-clip: padding-box;
  }
  .sm-main::-webkit-scrollbar-corner,
  .sm-side::-webkit-scrollbar-corner { background: transparent; }

  .sm-hint {
    color: rgba(255, 255, 255, 0.44);
    font-size: 13px;
    margin: 4px 0 0;
  }

  @media (max-width: 800px) {
    .sm-overlay { padding: 1rem; }
    .sm-panel {
      width: calc(100% - 1rem);
      border-radius: 20px;
    }
    .sm-body { flex-direction: column; }
    .sm-side {
      width: 100%;
      flex-direction: row;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      overflow-x: auto;
      padding: 12px;
    }
    .sm-side-item { width: auto; flex-shrink: 0; }
    .sm-card-grid { grid-template-columns: repeat(2, 1fr); }
    .sm-arrow { display: none; }
  }
</style>
