---
import SearchModal from './SearchModal.astro';
const { user } = Astro.locals;
const path = Astro.url.pathname;
const isHome = path === '/';
const initial = (user?.email ?? 'G').charAt(0).toUpperCase();
---
<nav class="topbar">
  <div class="topbar-inner">
  <a href="/" class="brand">
    <span class="logo" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 4h6v16H4zM14 4h6v9h-6zM14 15h6v5h-6z" fill="currentColor"/>
      </svg>
    </span>
    <span class="brand-text">Yourshelf</span>
  </a>

  {isHome ? (
    <button class="search" type="button" data-open-search aria-label="Open search">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
        <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="search-placeholder">Search for game titles, studio names...</span>
      <kbd class="search-kbd">Ctrl K</kbd>
    </button>
  ) : (
    <div class="links">
      <a href="/" class={path === '/' ? 'active' : ''}>Discover</a>
      <a href="/browse" class={path.startsWith('/browse') ? 'active' : ''}>Browse</a>
      <button type="button" data-open-search class={`link-btn${path.startsWith('/search') ? ' active' : ''}`}>Search</button>
    </div>
  )}

  <div class="account">
    {user ? (
      <a href="/profile" class="avatar" aria-label="Profile">{initial}</a>
    ) : (
      <>
        <a href="/login" class="quiet">Log in</a>
        <a href="/signup" class="signup">Sign up</a>
      </>
    )}
  </div>
  </div>
</nav>

<SearchModal />

<style>
  .topbar {
    background: #0e1014;
    border-bottom: 1px solid #1a1d24;
  }
  .topbar-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 1rem 2.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: #e6e8eb; text-decoration: none;
    font-weight: 700; font-size: 0.95rem; letter-spacing: -0.01em;
  }
  .logo { color: #a78bfa; display: inline-flex; }
  .search {
    justify-self: end;
    position: relative;
    display: flex; align-items: center; gap: 0.5rem;
    background: #15181f; border: 1px solid #20242c; border-radius: 999px;
    padding: 0.55rem 0.55rem 0.55rem 2.25rem;
    width: min(420px, 100%);
    color: #6b7280; cursor: pointer; font: inherit;
    text-align: left;
    transition: border-color 0.15s;
  }
  .search:hover, .search:focus { border-color: #2a3038; outline: none; }
  .search-icon { position: absolute; left: 0.9rem; color: #6b7280; }
  .search-placeholder {
    flex: 1; font-size: 0.82rem; color: #6b7280;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .search-kbd {
    background: #0e1014; border: 1px solid #20242c; color: #9aa3ad;
    padding: 0.15rem 0.45rem; border-radius: 6px;
    font-size: 0.7rem; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .links { display: flex; gap: 1.25rem; justify-self: end; align-items: center; }
  .links a, .link-btn {
    color: #9aa3ad; text-decoration: none; font-size: 0.88rem;
    background: transparent; border: 0; padding: 0; cursor: pointer; font: inherit;
  }
  .links a:hover, .links a.active, .link-btn:hover, .link-btn.active { color: #e6e8eb; }
  .account { display: flex; align-items: center; gap: 1rem; }
  .quiet { color: #9aa3ad; text-decoration: none; font-size: 0.85rem; }
  .quiet:hover { color: #e6e8eb; }
  .signup {
    background: #6366f1; color: white; text-decoration: none;
    padding: 0.45rem 0.9rem; border-radius: 999px; font-size: 0.85rem; font-weight: 500;
  }
  .signup:hover { background: #5457e0; }
  .avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #a78bfa);
    color: white; display: inline-flex; align-items: center; justify-content: center;
    font-weight: 600; font-size: 0.85rem; text-decoration: none;
  }

  @media (max-width: 900px) {
    .topbar-inner { padding: 0.85rem 1.25rem; gap: 0.75rem; }
    .search { width: 100%; }
  }
  @media (max-width: 640px) {
    .brand-text { display: none; }
    .search-kbd { display: none; }
  }
</style>
