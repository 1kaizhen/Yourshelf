---
import type { GameLite } from '../lib/api';

type CardItem = GameLite & {
  rating?: number | null;
  genres?: string[];
  hours?: number | null;
  href?: string;
  worth?: string | null;
};

interface Props {
  title: string;
  href?: string;
  items: CardItem[];
}

const { title, items } = Astro.props;
---

<section class="section">
  <header class="section-head">
    <h2>{title}</h2>
  </header>

  {items.length === 0 ? (
    <p class="empty">Nothing here yet.</p>
  ) : (
    <ul class="grid">
      {items.map((g) => {
        const isExternal = !!g.href;
        const linkHref = g.href ?? `/games/${g.igdb_id}`;
        return (
          <li>
            <a
              class="card"
              href={linkHref}
              target={isExternal ? '_blank' : undefined}
              rel={isExternal ? 'noopener noreferrer' : undefined}
            >
              <div class="cover">
                {g.cover_url ? (
                  <img src={g.cover_url} alt={g.name} loading="lazy" />
                ) : (
                  <div class="fallback"></div>
                )}
              </div>
              <div class="meta">
                <div class="text">
                  {g.rating != null && (
                    <div class="rating">{g.rating.toFixed(1)}/10 Rating</div>
                  )}
                  {g.worth && (
                    <div class="rating">Worth {g.worth}</div>
                  )}
                  <div class="name">{g.name}</div>
                </div>
                {g.genres && g.genres.length > 0 && (
                  <div class="tags">
                    {g.genres.slice(0, 4).map((t) => <span class="tag">{t}</span>)}
                  </div>
                )}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</section>

<style>
  .section { margin-bottom: 72px; }
  .section-head { margin-bottom: 14px; }
  .section-head h2 {
    margin: 0;
    color: white;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.6px;
  }

  .empty { color: #8a93a0; font-size: 0.85rem; }

  .grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px;
  }

  .card {
    display: flex; flex-direction: column; gap: 12px;
    text-decoration: none; color: inherit;
    transition: transform 0.15s;
  }
  .card:hover { transform: translateY(-2px); }
  .card:hover .cover { box-shadow: 0 12px 28px rgba(0, 0, 0, 0.5); }

  .cover {
    position: relative;
    aspect-ratio: 264 / 352;
    border-radius: 12px;
    overflow: hidden;
    background: #11151a;
    transition: box-shadow 0.15s;
  }
  .cover img, .fallback {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .fallback { background: linear-gradient(135deg, #1a1f26, #11151a); }

  .meta { display: flex; flex-direction: column; gap: 8px; }
  .text { display: flex; flex-direction: column; gap: 2px; }
  .rating {
    color: rgba(255, 255, 255, 0.66);
    font-size: 12px;
    font-weight: 500;
    line-height: 1.4;
  }
  .name {
    color: white;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.48px;
    word-break: break-word;
  }

  .tags { display: flex; flex-wrap: wrap; gap: 3.5px; align-items: center; }
  .tag {
    background: #252525;
    color: white;
    font-size: 8.75px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0.4375px;
    text-transform: uppercase;
    padding: 3.5px 7px;
    border-radius: 999px;
    white-space: nowrap;
  }

  @media (max-width: 1100px) {
    .grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 768px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
